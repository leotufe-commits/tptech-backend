/// ///////////////////////////
/// ARTÍCULOS
/// ///////////////////////////
model Article {
  id               String           @id @default(cuid())
  jewelryId        String
  code             String
  name             String
  description      String           @default("")
  categoryId       String?
  status           ArticleStatus    @default(DRAFT)
  stockMode        StockMode        @default(NO_STOCK)
  hechuraPrice     Decimal?         @db.Decimal(14, 4)
  hechuraPriceMode HechuraPriceMode @default(FIXED)
  mermaPercent     Decimal?         @db.Decimal(5, 2)
  mainImageUrl     String           @default("")
  isFavorite       Boolean          @default(false)
  isActive         Boolean          @default(true)
  notes            String           @default("")
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  jewelry         Jewelry                   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  category        ArticleCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  compositions    ArticleMetalComposition[]
  variants        ArticleVariant[]
  attributeValues ArticleAttributeValue[]
  images          ArticleImage[]
  stock           ArticleStock[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([categoryId])
  @@index([jewelryId, status])
  @@index([jewelryId, isActive])
  @@index([deletedAt])
}

model ArticleMetalComposition {
  id          String      @id @default(cuid())
  articleId   String
  jewelryId   String
  variantId   String
  grams       Decimal     @db.Decimal(10, 4)
  isBase      Boolean     @default(false)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())

  article      Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  metalVariant MetalVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([articleId, variantId])
  @@index([articleId])
  @@index([jewelryId])
}

model ArticleVariant {
  id                   String    @id @default(cuid())
  articleId            String
  jewelryId            String
  code                 String
  name                 String
  weightOverride       Decimal?  @db.Decimal(10, 4)
  hechuraPriceOverride Decimal?  @db.Decimal(14, 4)
  priceOverride        Decimal?  @db.Decimal(14, 4)
  imageUrl             String    @default("")
  isActive             Boolean   @default(true)
  sortOrder            Int       @default(0)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  article Article        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  stock   ArticleStock[]

  @@unique([articleId, code])
  @@index([articleId])
  @@index([jewelryId])
}

model ArticleAttributeValue {
  id           String   @id @default(cuid())
  articleId    String
  jewelryId    String
  assignmentId String
  value        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article    Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assignment ArticleCategoryAttribute @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([articleId, assignmentId])
  @@index([articleId])
  @@index([assignmentId])
}

model ArticleImage {
  id        String   @id @default(cuid())
  articleId String
  jewelryId String
  url       String
  label     String   @default("")
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([jewelryId])
}

model ArticleStock {
  id          String    @id @default(cuid())
  articleId   String
  variantId   String?
  warehouseId String
  jewelryId   String
  quantity    Decimal   @default(0) @db.Decimal(14, 4)
  updatedAt   DateTime  @updatedAt

  article   Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  variant   ArticleVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, warehouseId, articleId, variantId])
  @@index([articleId])
  @@index([jewelryId])
  @@index([warehouseId])
}

/// ///////////////////////////
/// ENUMS — ARTÍCULOS
/// ///////////////////////////
enum ArticleStatus {
