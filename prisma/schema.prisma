// Etapa D2 — Redondeo físico de gramos por metal padre (POLICY §R-Rounding-13).
// Enums INDEPENDIENTES de RoundingMode/RoundingDirection. Los del redondeo
// monetario (TEN, HUNDRED) no aplican a gramos físicos; los del físico
// (HALF, QUARTER) no aplican a redondeo monetario.

// Discriminador del dominio del metal en redondeo BREAKDOWN del comprobante.
enum DocumentRoundingMetalDomain {
  MONETARY // Default — redondea metal $ (capa 15, Etapa 1B). Comportamiento actual.
  PHYSICAL // Etapa D — redondea gramos físicos por metal padre (capa 16).
}

// Etapa D' (POLICY §R-Rounding-15) — scope del redondeo comercial por lista.
//   · PER_LINE_LEGACY (default): redondeo aplicado por `applyPriceList` por línea
//     y antes de impuestos. Comportamiento histórico — preserva back-compat con
//     todos los tenants existentes.
//   · PER_DOCUMENT: el motor de lista suprime su redondeo per-línea; el redondeo
//     se aplica POST-tax a nivel documento por `computeSaleDocumentTotals`
//     (capa nueva, post-tax, pre-shipping/payment).
enum CommercialRoundingScope {
  PER_LINE_LEGACY
  PER_DOCUMENT
}

// Modos de redondeo físico de gramos.
//   · NONE      → no redondea ese metal (passthrough explícito).
//   · INTEGER   → múltiplos de 1.
//   · DECIMAL_1 → múltiplos de 0,1.
//   · DECIMAL_2 → múltiplos de 0,01.
//   · HALF      → múltiplos de 0,5.
//   · QUARTER   → múltiplos de 0,25.
enum PhysicalRoundingMode {
  NONE
  INTEGER
  DECIMAL_1
  DECIMAL_2
  HALF
  QUARTER
}

// Dirección del redondeo físico — empates NEAREST van hacia arriba (half-up).
enum PhysicalRoundingDirection {
  NEAREST
  UP
  DOWN
}

enum RoundingApplyOn {
  PRICE // Sobre el precio de lista (antes de descuentos e impuestos) — DEFAULT
  NET // Sobre el precio neto final (después de descuentos, antes de impuestos)
  TOTAL // Sobre el total con impuestos (después de todos los cálculos)
}

// Etapa 1B — Scope del redondeo por comprobante (configurado en Jewelry).
//   · UNIFIED:   redondea el total final (comportamiento histórico).
//   · BREAKDOWN: redondea por separado metal y hechura del documento.
//   · BOTH:      cascada controlada — BREAKDOWN primero, UNIFIED al final.
// Default UNIFIED para mantener compatibilidad con tenants existentes.
enum DocumentRoundingScope {
  UNIFIED
  BREAKDOWN
  BOTH
}

