enum CommissionType {
  NONE
  PERCENTAGE
  FIXED_AMOUNT
}

enum CommissionBase {
  TOTAL                   // sobre el total de la línea (cantidad × precio − descuento), antes de impuestos
  TOTAL_AFTER_DISCOUNTS   // sobre el total de la línea ajustado por canal + cupón, antes de impuestos
  TOTAL_AFTER_PAYMENT     // sobre el total ajustado por canal + cupón + forma de pago (actualizado al cobrar)
  METAL                   // sobre el componente metal del breakdownSnapshot × cantidad
  HECHURA                 // sobre el componente hechura del breakdownSnapshot × cantidad
  METAL_Y_HECHURA         // sobre metal + hechura combinados del breakdownSnapshot × cantidad
  HECHURA_AFTER_DISCOUNTS // sobre el componente hechura ajustado por canal + cupón
}

