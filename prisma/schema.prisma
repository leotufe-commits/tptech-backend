  ACTIVE
  DISCONTINUED
  ARCHIVED
}

enum StockMode {
  NO_STOCK
  BY_ARTICLE
  BY_MATERIAL
}

enum HechuraPriceMode {
  FIXED
  PER_GRAM
}
