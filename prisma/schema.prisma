/// ///////////////////////////
/// ///////////////////////////
/// NOTA ARQUITECTURAL: Los comprobantes futuros (facturas, remitos, etc.)
/// guardarán un snapshot propio de la entidad, lista de precios, moneda,
/// condiciones y reglas aplicadas en el momento de su creación.
/// Nunca deben recalcularse leyendo la ficha actual de la entidad.
/// ///////////////////////////
model CommercialEntity {
  id                  String           @id @default(cuid())
  jewelryId           String
  code                String           // CE-0001 — generado una sola vez al crear, nunca cambia
  displayName         String           // calculado en backend: COMPANY=tradeName||companyName, PERSON="Apellido, Nombre"

  entityType          EntityType       @default(PERSON)

  // Roles — al menos uno debe ser true (validado en service)
  isClient            Boolean          @default(false)
  isSupplier          Boolean          @default(false)

  // Datos persona física
  firstName           String           @default("")
  lastName            String           @default("")

  // Datos empresa
  companyName         String           @default("") // Razón social
  tradeName           String           @default("") // Nombre de fantasía

  // Contacto primario (acceso rápido en listados)
  email               String           @default("")
  phone               String           @default("")

  // Fiscal
  documentType        String           @default("")
  documentNumber      String           @default("")
  ivaCondition        String           @default("")

  // Cuenta corriente
  balanceType         BalanceType      @default(UNIFIED)
  creditLimitClient   Decimal?         @db.Decimal(14, 2)
  creditLimitSupplier Decimal?         @db.Decimal(14, 2)

  // Defaults comerciales
  priceListId         String?          // lista de precios habitual (FK a PriceList)
  currencyId          String?          // moneda habitual de facturación (FK a Currency)

  // Estado y trazabilidad
  isActive            Boolean          @default(true)
  deletedAt           DateTime?
  sourceType          EntitySourceType @default(MANUAL)
  mergedIntoEntityId  String?          // si fue fusionada, referencia al destino (nunca se borra la origen)
  notes               String           @default("")
  avatarUrl           String           @default("")

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  jewelry         Jewelry              @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  priceList       PriceList?           @relation("EntityPriceList", fields: [priceListId], references: [id], onDelete: SetNull)
  currency        Currency?            @relation("EntityCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  addresses       EntityAddress[]
  contacts        EntityContact[]
  commercialRules EntityCommercialRule[]
  taxOverrides    EntityTaxOverride[]
  balanceEntries  EntityBalanceEntry[]
  attachments     EntityAttachment[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isClient, isActive])
  @@index([jewelryId, isSupplier, isActive])
  @@index([jewelryId, displayName])
  @@index([jewelryId, documentNumber])
  @@index([priceListId])
  @@index([currencyId])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model EntityAddress {
  id           String      @id @default(cuid())
  entityId     String
  jewelryId    String
  type         AddressType @default(OTHER)
