generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// ///////////////////////////
/// ///////////////////////////
model Jewelry {
  id                         String                     @id @default(cuid())
  name                       String
  firstName                  String
  lastName                   String
  phoneCountry               String
  phoneNumber                String
  street                     String
  number                     String
  city                       String
  province                   String
  postalCode                 String
  country                    String
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  cuit                       String                     @default("")
  email                      String                     @default("")
  ivaCondition               String                     @default("")
  legalName                  String                     @default("")
  logoUrl                    String                     @default("")
  notes                      String                     @default("")
  website                    String                     @default("")
  quickSwitchEnabled         Boolean                    @default(false)
  pinLockEnabled             Boolean                    @default(false)
  pinLockRequireOnUserSwitch Boolean                    @default(false)
  pinLockTimeoutSec          Int                        @default(120)
  deletedAt                  DateTime?
  auditLogs                  AuditLog[]
  catalogItems               CatalogItem[]
  currencies                 Currency[]
  movements                  InventoryMovement[]
  movementLines              InventoryMovementLine[]
  attachments                JewelryAttachment[]
  metals                     Metal[]
  metalRefHistory            MetalRefValueHistory[]
  variantValueHistory        MetalVariantValueHistory[]
  roles                      Role[]
  users                      User[]
  warehouses                 Warehouse[]
  warehouseStocks            WarehouseStock[]
  articleCategories          ArticleCategory[]
  taxes                      Tax[]
  paymentMethods             PaymentMethod[]
  shippingCarriers           ShippingCarrier[]
  sellers                    Seller[]
  priceLists                 PriceList[]

  @@index([createdAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model JewelryAttachment {
  id        String    @id @default(cuid())
  jewelryId String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  jewelry   Jewelry   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([jewelryId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Warehouse {
  id            String              @id @default(cuid())
  jewelryId     String
  name          String
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  code          String              @default("")
  notes         String              @default("")
  attn          String              @default("")
  city          String              @default("")
  country       String              @default("")
  location      String              @default("")
  number        String              @default("")
  phoneCountry  String              @default("")
  phoneNumber   String              @default("")
  postalCode    String              @default("")
  province      String              @default("")
  street        String              @default("")
  fromMovements InventoryMovement[] @relation("MovementFromWarehouse")
  toMovements   InventoryMovement[] @relation("MovementToWarehouse")
  movements     InventoryMovement[] @relation("MovementWarehouse")
  favoriteUsers User[]              @relation("UserFavoriteWarehouse")
  jewelry       Jewelry             @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  stocks        WarehouseStock[]
  sellers       SellerWarehouse[]

  @@index([jewelryId])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model InventoryMovement {
  id              String                  @id @default(cuid())
  jewelryId       String
  kind            InventoryMovementKind
  code            String                  @default("")
  note            String                  @default("")
  effectiveAt     DateTime
  warehouseId     String?
  fromWarehouseId String?
  toWarehouseId   String?
  createdById     String?
  deletedAt       DateTime?
  voidedAt        DateTime?
  voidedNote      String                  @default("")
  voidedById      String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  createdBy       User?                   @relation("MovementCreatedBy", fields: [createdById], references: [id])
  fromWarehouse   Warehouse?              @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  jewelry         Jewelry                 @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse?              @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  voidedBy        User?                   @relation("MovementVoidedBy", fields: [voidedById], references: [id])
  warehouse       Warehouse?              @relation("MovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  lines           InventoryMovementLine[]

  @@index([jewelryId, createdAt])
  @@index([jewelryId, effectiveAt])
  @@index([jewelryId, kind])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([deletedAt])
}

model InventoryMovementLine {
  id         String            @id @default(cuid())
  jewelryId  String
  movementId String
  variantId  String
  grams      Decimal           @db.Decimal(18, 6)
  createdAt  DateTime          @default(now())
  jewelry    Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  movement   InventoryMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  variant    MetalVariant      @relation(fields: [variantId], references: [id])

  @@index([jewelryId, createdAt])
  @@index([movementId])
  @@index([variantId])
}

/// ///////////////////////////
/// ///////////////////////////
model WarehouseStock {
  id          String       @id @default(cuid())
  jewelryId   String
  warehouseId String
  variantId   String
  grams       Decimal      @default(0) @db.Decimal(18, 6)
  pieces      Int          @default(0)
  updatedAt   DateTime     @updatedAt
  jewelry     Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  variant     MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, warehouseId, variantId])
  @@index([jewelryId, warehouseId])
  @@index([warehouseId])
  @@index([variantId])
}

/// ///////////////////////////
/// ///////////////////////////
model User {
  id                         String                     @id @default(cuid())
  email                      String
  password                   String
  name                       String?
  status                     UserStatus                 @default(ACTIVE)
  tokenVersion               Int                        @default(0)
  avatarUrl                  String?
  jewelryId                  String
  favoriteWarehouseId        String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  city                       String                     @default("")
  country                    String                     @default("")
  documentNumber             String                     @default("")
  documentType               String                     @default("")
  notes                      String                     @default("")
  number                     String                     @default("")
  phoneCountry               String                     @default("")
  phoneNumber                String                     @default("")
  postalCode                 String                     @default("")
  province                   String                     @default("")
  street                     String                     @default("")
  deletedAt                  DateTime?
  quickPinFailedCount        Int                        @default(0)
  quickPinHash               String?
  quickPinLockedUntil        DateTime?
  quickPinUpdatedAt          DateTime?
  quickPinEnabled            Boolean                    @default(false)
  auditLogs                  AuditLog[]
  authTokens                 AuthToken[]
  currencyRatesCreated       CurrencyRate[]             @relation("CurrencyRateCreatedBy")
  movementsCreated           InventoryMovement[]        @relation("MovementCreatedBy")
  movementsVoided            InventoryMovement[]        @relation("MovementVoidedBy")
  metalQuotesCreated         MetalQuote[]
  metalRefHistoryCreated     MetalRefValueHistory[]     @relation("MetalRefHistoryCreatedBy")
  variantValueHistoryCreated MetalVariantValueHistory[] @relation("VariantValueHistoryCreatedBy")
  favoriteWarehouse          Warehouse?                 @relation("UserFavoriteWarehouse", fields: [favoriteWarehouseId], references: [id])
  jewelry                    Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  attachments                UserAttachment[]
  permissionOverrides        UserPermissionOverride[]
  roles                      UserRole[]

  @@unique([jewelryId, email])
  @@index([jewelryId])
  @@index([jewelryId, status])
  @@index([favoriteWarehouseId])
  @@index([jewelryId, deletedAt])
  @@index([quickPinUpdatedAt])
  @@index([quickPinEnabled])
}

/// ///////////////////////////
/// ///////////////////////////
model UserAttachment {
  id        String    @id @default(cuid())
  userId    String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model AuthToken {
  id            String    @id @default(cuid())
  type          String    @default("reset")
  jti           String    @unique
  userId        String
  emailSnapshot String    @default("")
  ip            String?
  userAgent     String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type, expiresAt])
  @@index([usedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Role {
  id          String           @id @default(cuid())
  jewelryId   String
  name        String
  isSystem    Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  displayName String?
  jewelry     Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, deletedAt])
}

model Permission {
  id        String                   @id @default(cuid())
  module    PermModule
  action    PermAction
  createdAt DateTime                 @default(now())
  roles     RolePermission[]
  overrides UserPermissionOverride[]

  @@unique([module, action])
  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserPermissionOverride {
  id           String         @id @default(cuid())
  userId       String
  permissionId String
  effect       OverrideEffect
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

/// ///////////////////////////
/// ///////////////////////////
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String
  success   Boolean
  userId    String?
  jewelryId String?
  ip        String?
  userAgent String?
  meta      Json?
  jewelry   Jewelry? @relation(fields: [jewelryId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([success])
  @@index([jewelryId, createdAt])
  @@index([userId, createdAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Currency {
  id        String         @id @default(cuid())
  jewelryId String
  code      String
  name      String
  symbol    String
  isBase    Boolean        @default(false)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  jewelry   Jewelry        @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  rates     CurrencyRate[]
  quotes    MetalQuote[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isBase])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model CurrencyRate {
  id          String   @id @default(cuid())
  currencyId  String
  rate        Decimal  @db.Decimal(18, 6)
  effectiveAt DateTime
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("CurrencyRateCreatedBy", fields: [createdById], references: [id])
  currency    Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@index([currencyId, effectiveAt])
  @@index([createdById])
}

/// ///////////////////////////
/// ///////////////////////////
model Metal {
  id                  String                     @id @default(cuid())
  jewelryId           String
  name                String
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  symbol              String                     @default("")
  referenceValue      Decimal                    @default(0) @db.Decimal(18, 6)
  sortOrder           Int                        @default(0)
  deletedAt           DateTime?
  jewelry             Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  refHistory          MetalRefValueHistory[]
  variants            MetalVariant[]
  variantValueHistory MetalVariantValueHistory[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, sortOrder])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model MetalVariant {
  id            String                     @id @default(cuid())
  metalId       String
  name          String
  sku           String
  purity        Decimal                    @db.Decimal(6, 4)
  isFavorite    Boolean                    @default(false)
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  saleFactor    Decimal                    @default(1.0) @db.Decimal(12, 6)
  deletedAt     DateTime?
  movementLines InventoryMovementLine[]
  quotes        MetalQuote[]
  metal         Metal                      @relation(fields: [metalId], references: [id], onDelete: Cascade)
  valueHistory  MetalVariantValueHistory[]
  stocks        WarehouseStock[]

  @@unique([metalId, sku])
  @@index([metalId])
  @@index([metalId, isActive])
  @@index([metalId, isFavorite])
  @@index([deletedAt])
  @@index([metalId, deletedAt])
}

model MetalQuote {
  id          String       @id @default(cuid())
  variantId   String
  currencyId  String
  effectiveAt DateTime
  createdAt   DateTime     @default(now())
  createdById String?
  price       Decimal      @db.Decimal(18, 6)
  createdBy   User?        @relation(fields: [createdById], references: [id])
  currency    Currency     @relation(fields: [currencyId], references: [id])
  variant     MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, effectiveAt])
  @@index([variantId, currencyId, effectiveAt])
  @@index([currencyId])
  @@index([createdById])
}

model MetalRefValueHistory {
  id             String   @id @default(cuid())
  jewelryId      String
  metalId        String
  referenceValue Decimal  @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime @default(now())
  createdById    String?
  createdBy      User?    @relation("MetalRefHistoryCreatedBy", fields: [createdById], references: [id])
  jewelry        Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal          Metal    @relation(fields: [metalId], references: [id], onDelete: Cascade)

  @@index([jewelryId, metalId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model MetalVariantValueHistory {
  id             String       @id @default(cuid())
  jewelryId      String
  metalId        String
  variantId      String
  referenceValue Decimal      @db.Decimal(18, 6)
  purity         Decimal      @db.Decimal(6, 4)
  saleFactor     Decimal      @db.Decimal(12, 6)
  finalSalePrice Decimal      @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime     @default(now())
  createdById    String?
  createdBy      User?        @relation("VariantValueHistoryCreatedBy", fields: [createdById], references: [id])
  jewelry        Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal          Metal        @relation(fields: [metalId], references: [id], onDelete: Cascade)
  variant        MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([jewelryId, variantId, effectiveAt])
  @@index([variantId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model CatalogItem {
  id         String      @id @default(cuid())
  jewelryId  String
  type       CatalogType
  label      String
  isActive   Boolean     @default(true)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  isFavorite Boolean     @default(false)
  deletedAt  DateTime?
  jewelry    Jewelry     @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, type, label])
  @@index([jewelryId])
  @@index([jewelryId, type, isActive])
  @@index([jewelryId, type, isFavorite])
  @@index([deletedAt])
  @@index([jewelryId, type, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleCategory {
  id          String    @id @default(cuid())
  jewelryId   String
  parentId    String?
  name        String
  description String    @default("")
  imageUrl    String    @default("")
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jewelry  Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  parent   ArticleCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ArticleCategory[] @relation("CategoryTree")
  priceLists PriceList[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([parentId])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Tax {
  id              String             @id @default(cuid())
  jewelryId       String
  name            String
  code            String             @default("")
  taxType         TaxType            @default(OTHER)
  calculationType TaxCalculationType @default(PERCENTAGE)
  rate            Decimal?           @db.Decimal(10, 4)
  fixedAmount     Decimal?           @db.Decimal(18, 2)
  applyOn         TaxApplyOn         @default(TOTAL)
  includedInPrice Boolean            @default(false)
  validFrom       DateTime?
  validTo         DateTime?
  isActive        Boolean            @default(true)
  sortOrder       Int                @default(0)
  notes           String             @default("")
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model PaymentMethod {
  id              String                 @id @default(cuid())
  jewelryId       String
  name            String
  code            String                 @default("")
  type            PaymentMethodType      @default(OTHER)
  adjustmentType  PaymentAdjustmentType  @default(NONE)
  adjustmentValue Decimal?               @db.Decimal(10, 4)
  isFavorite      Boolean                @default(false)
  isActive        Boolean                @default(true)
  sortOrder       Int                    @default(0)
  notes           String                 @default("")
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  jewelry          Jewelry                  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  installmentPlans PaymentInstallmentPlan[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

model PaymentInstallmentPlan {
  id              String   @id @default(cuid())
  paymentMethodId String
  jewelryId       String
  installments    Int
  interestRate    Decimal  @db.Decimal(10, 4)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@index([paymentMethodId])
  @@index([jewelryId])
}

/// ///////////////////////////
/// ///////////////////////////
model ShippingCarrier {
  id                     String         @id @default(cuid())
  jewelryId              String
  name                   String
  code                   String         @default("")
  logoUrl                String         @default("")
  trackingUrl            String         @default("")
  freeShippingThreshold  Decimal?       @db.Decimal(18, 2)
  isFavorite             Boolean        @default(false)
  isActive               Boolean        @default(true)
  sortOrder              Int            @default(0)
  notes                  String         @default("")
  deletedAt              DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  jewelry Jewelry        @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  rates   ShippingRate[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

model ShippingRate {
  id              String              @id @default(cuid())
  carrierId       String
  jewelryId       String
  name            String
  zone            String              @default("")
  calculationMode ShippingCalcMode    @default(FIXED)
  fixedPrice      Decimal?            @db.Decimal(18, 2)
  pricePerKg      Decimal?            @db.Decimal(18, 4)
  minWeight       Decimal?            @db.Decimal(10, 3)
  maxWeight       Decimal?            @db.Decimal(10, 3)
  isActive        Boolean             @default(true)
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  carrier ShippingCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  @@index([carrierId])
  @@index([jewelryId])
}

/// ///////////////////////////
/// ///////////////////////////
model Seller {
  id               String         @id @default(cuid())
  jewelryId        String
  firstName        String
  lastName         String
  displayName      String         @default("")
  documentType     String         @default("")
  documentNumber   String         @default("")
  email            String         @default("")
  phone            String         @default("")
  commissionType   CommissionType @default(NONE)
  commissionValue  Decimal?       @db.Decimal(10, 4)
  userId           String?
  isFavorite       Boolean        @default(false)
  isActive         Boolean        @default(true)
  sortOrder        Int            @default(0)
  notes            String         @default("")
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  jewelry    Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  warehouses SellerWarehouse[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

model SellerWarehouse {
  sellerId    String
  warehouseId String
  jewelryId   String

  seller    Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([sellerId, warehouseId])
  @@index([sellerId])
  @@index([warehouseId])
  @@index([jewelryId])
}

/// ///////////////////////////
/// ///////////////////////////
model PriceList {
  id              String          @id @default(cuid())
  jewelryId       String
  name            String
  code            String          @default("")
  description     String          @default("")
  scope           PriceListScope  @default(GENERAL)
  categoryId      String?
  channelId       String?
  clientId        String?
  mode            PriceListMode   @default(MARGIN_TOTAL)
  marginTotal     Decimal?        @db.Decimal(10, 4)
  marginMetal     Decimal?        @db.Decimal(10, 4)
  marginHechura   Decimal?        @db.Decimal(10, 4)
  costPerGram     Decimal?        @db.Decimal(18, 6)
  surcharge       Decimal?        @db.Decimal(10, 4)
  minimumPrice    Decimal?        @db.Decimal(18, 2)
  roundingTarget  RoundingTarget  @default(NONE)
  roundingMode    RoundingMode    @default(NONE)
  roundingDirection RoundingDirection @default(NEAREST)
  validFrom       DateTime?
  validTo         DateTime?
  isFavorite      Boolean         @default(false)
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  notes           String          @default("")
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  jewelry  Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  category ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, scope])
  @@index([categoryId])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

