enum UnitType {
  QUANTITY
  WEIGHT
  LENGTH
  VOLUME
  OTHER
}

model Unit {
  id         String    @id @default(cuid())
  jewelryId  String
  name       String
  code       String
  type       UnitType
  isSystem   Boolean   @default(false)
  isFavorite Boolean   @default(false)
  isActive   Boolean   @default(true)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, type, code])
  @@unique([jewelryId, type, name])
  @@index([jewelryId, type, isActive])
  @@index([jewelryId, type, isFavorite])
  @@index([deletedAt])
}

enum TaxType {
  IVA
  INTERNAL
  PERCEPTION
  RETENTION
  OTHER
}

enum TaxCalculationType {
  PERCENTAGE
  FIXED_AMOUNT
  PERCENTAGE_PLUS_FIXED
}

enum TaxApplyOn {
  TOTAL
  METAL
  HECHURA
  METAL_Y_HECHURA
  SUBTOTAL_AFTER_DISCOUNT
