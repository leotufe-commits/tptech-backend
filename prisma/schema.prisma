// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////
// JOYERÍA (EMPRESA)
//////////////////////////////
model Jewelry {
  id        String @id @default(cuid())
  name      String
  firstName String
  lastName  String

  phoneCountry String
  phoneNumber  String
  street       String
  number       String
  city         String
  province     String
  postalCode   String
  country      String

  logoUrl      String @default("")
  legalName    String @default("")
  cuit         String @default("")
  ivaCondition String @default("")
  email        String @default("")
  website      String @default("")
  notes        String @default("")

  quickSwitchEnabled         Boolean @default(false)
  pinLockEnabled             Boolean @default(false)
  pinLockTimeoutSec          Int     @default(120)
  pinLockRequireOnUserSwitch Boolean @default(false)

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs    AuditLog[]
  roles        Role[]
  users        User[]
  warehouses   Warehouse[]
  attachments  JewelryAttachment[]
  catalogItems CatalogItem[]

  // ✅ Valuación
  currencies Currency[]
  metals     Metal[]

  // ✅ historial valor ref metales
  metalRefHistory MetalRefValueHistory[]

  // ✅ historial valor variante (Opción B PRO)
  variantValueHistory MetalVariantValueHistory[]

  // ✅ Inventario / movimientos
  movements     InventoryMovement[]
  movementLines InventoryMovementLine[]

  // ✅ Inventario / stock materializado (para poder validar "stock cero" al borrar)
  warehouseStocks WarehouseStock[]

  @@index([createdAt])
  @@index([deletedAt])
}

//////////////////////////////
// ADJUNTOS DE EMPRESA
//////////////////////////////
model JewelryAttachment {
  id        String  @id @default(cuid())
  jewelryId String
  jewelry   Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  url      String
  filename String
  mimeType String
  size     Int

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([jewelryId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

//////////////////////////////
// ALMACENES
//////////////////////////////
model Warehouse {
  id        String @id @default(cuid())
  jewelryId String

  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  name String
  code String @default("")

  phoneCountry String @default("")
  phoneNumber  String @default("")

  attn       String @default("")
  street     String @default("")
  number     String @default("")
  city       String @default("")
  province   String @default("")
  postalCode String @default("")
  country    String @default("")

  location String @default("")
  notes    String @default("")

  isActive Boolean @default(true)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  //////////////////////////////
  // RELACIONES
  //////////////////////////////

  movements     InventoryMovement[] @relation("MovementWarehouse")
  fromMovements InventoryMovement[] @relation("MovementFromWarehouse")
  toMovements   InventoryMovement[] @relation("MovementToWarehouse")

  favoriteUsers User[] @relation("UserFavoriteWarehouse")

  // ✅ Stock materializado por variante (para validar borrado)
  stocks WarehouseStock[]

  @@index([jewelryId])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

//////////////////////////////
// ✅ INVENTARIO: MOVIMIENTOS (gramos)
//////////////////////////////
enum InventoryMovementKind {
  IN
  OUT
  TRANSFER
  ADJUST
}

model InventoryMovement {
  id        String @id @default(cuid())
  jewelryId String

  kind InventoryMovementKind

  // opcional (correlativo / código corto)
  code String @default("")

  note        String   @default("")
  effectiveAt DateTime

  // IN/OUT/ADJUST
  warehouseId String?
  warehouse   Warehouse? @relation("MovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)

  // TRANSFER
  fromWarehouseId String?
  fromWarehouse   Warehouse? @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)

  toWarehouseId String?
  toWarehouse   Warehouse? @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)

  createdById String?
  createdBy   User?   @relation("MovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  // anulación (soft delete + datos)
  deletedAt  DateTime?
  voidedAt   DateTime?
  voidedNote String    @default("")
  voidedById String?
  voidedBy   User?     @relation("MovementVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jewelry Jewelry                 @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  lines   InventoryMovementLine[]

  @@index([jewelryId, createdAt])
  @@index([jewelryId, effectiveAt])
  @@index([jewelryId, kind])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([deletedAt])
}

model InventoryMovementLine {
  id         String @id @default(cuid())
  jewelryId  String
  movementId String
  variantId  String

  // ✅ gramos
  grams Decimal @db.Decimal(18, 6)

  createdAt DateTime @default(now())

  jewelry  Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  movement InventoryMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  variant  MetalVariant      @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([jewelryId, createdAt])
  @@index([movementId])
  @@index([variantId])
}

//////////////////////////////
// ✅ INVENTARIO: STOCK MATERIALIZADO (PRO)
// - Permite validar "stock cero" al eliminar almacén
// - Se actualiza cuando se crean/anulan movimientos
//////////////////////////////
model WarehouseStock {
  id          String @id @default(cuid())
  jewelryId   String
  warehouseId String
  variantId   String

  // ✅ stock actual
  grams  Decimal @default(0) @db.Decimal(18, 6)
  pieces Int     @default(0)

  updatedAt DateTime @updatedAt

  jewelry   Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  warehouse Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant   MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, warehouseId, variantId])
  @@index([jewelryId, warehouseId])
  @@index([warehouseId])
  @@index([variantId])
}

//////////////////////////////
// USUARIOS
//////////////////////////////
model User {
  id       String     @id @default(cuid())
  email    String
  password String
  name     String?
  status   UserStatus @default(ACTIVE)

  tokenVersion Int @default(0)

  avatarUrl String?
  jewelryId String

  favoriteWarehouseId String?
  deletedAt           DateTime?

  phoneCountry   String @default("")
  phoneNumber    String @default("")
  documentType   String @default("")
  documentNumber String @default("")
  street         String @default("")
  number         String @default("")
  city           String @default("")
  province       String @default("")
  postalCode     String @default("")
  country        String @default("")
  notes          String @default("")

  quickPinHash        String?
  quickPinEnabled     Boolean   @default(false)
  quickPinUpdatedAt   DateTime?
  quickPinFailedCount Int       @default(0)
  quickPinLockedUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jewelry           Jewelry    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  favoriteWarehouse Warehouse? @relation("UserFavoriteWarehouse", fields: [favoriteWarehouseId], references: [id])

  roles               UserRole[]
  permissionOverrides UserPermissionOverride[]
  attachments         UserAttachment[]
  auditLogs           AuditLog[]

  authTokens AuthToken[]

  currencyRatesCreated   CurrencyRate[]         @relation("CurrencyRateCreatedBy")
  metalRefHistoryCreated MetalRefValueHistory[] @relation("MetalRefHistoryCreatedBy")

  // ✅ NUEVO: inverso de MetalQuote.createdBy (sin @relation)
  metalQuotesCreated MetalQuote[]

  // ✅ historial valor variante creado por usuario (Opción B PRO)
  variantValueHistoryCreated MetalVariantValueHistory[] @relation("VariantValueHistoryCreatedBy")

  // ✅ Movimientos
  movementsCreated InventoryMovement[] @relation("MovementCreatedBy")
  movementsVoided  InventoryMovement[] @relation("MovementVoidedBy")

  @@unique([jewelryId, email])
  @@index([jewelryId])
  @@index([jewelryId, status])
  @@index([favoriteWarehouseId])
  @@index([jewelryId, deletedAt])
  @@index([quickPinUpdatedAt])
  @@index([quickPinEnabled])
}

//////////////////////////////
// ADJUNTOS DE USUARIO
//////////////////////////////
model UserAttachment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url      String
  filename String
  mimeType String
  size     Int

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, deletedAt])
}

//////////////////////////////
// AUTH TOKENS
//////////////////////////////
model AuthToken {
  id   String @id @default(cuid())
  type String @default("reset")
  jti  String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailSnapshot String  @default("")
  ip            String?
  userAgent     String?

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type, expiresAt])
  @@index([usedAt])
}

//////////////////////////////
// ROLES / PERMISOS
//////////////////////////////
model Role {
  id          String    @id @default(cuid())
  jewelryId   String
  name        String
  displayName String?
  isSystem    Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jewelry     Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, deletedAt])
}

model Permission {
  id        String     @id @default(cuid())
  module    PermModule
  action    PermAction
  createdAt DateTime   @default(now())

  roles     RolePermission[]
  overrides UserPermissionOverride[]

  @@unique([module, action])
  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserPermissionOverride {
  id           String         @id @default(cuid())
  userId       String
  permissionId String
  effect       OverrideEffect

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

//////////////////////////////
// AUDITORÍA (NO SE BORRA)
//////////////////////////////
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action    String
  success   Boolean
  userId    String?
  jewelryId String?
  ip        String?
  userAgent String?
  meta      Json?

  user    User?    @relation(fields: [userId], references: [id])
  jewelry Jewelry? @relation(fields: [jewelryId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([success])
  @@index([jewelryId, createdAt])
  @@index([userId, createdAt])
}

//////////////////////////////
// VALUACIÓN: MONEDAS (FX)
//////////////////////////////
model Currency {
  id        String @id @default(cuid())
  jewelryId String
  code      String
  name      String
  symbol    String

  isBase   Boolean @default(false)
  isActive Boolean @default(true)

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jewelry Jewelry        @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  rates   CurrencyRate[]
  quotes  MetalQuote[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isBase])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model CurrencyRate {
  id          String   @id @default(cuid())
  currencyId  String
  rate        Decimal  @db.Decimal(18, 6)
  effectiveAt DateTime

  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation("CurrencyRateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  currency Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@index([currencyId, effectiveAt])
  @@index([createdById])
}

//////////////////////////////
// VALUACIÓN: METALES / VARIANTES
//////////////////////////////
model Metal {
  id        String @id @default(cuid())
  jewelryId String
  name      String
  symbol    String @default("")

  referenceValue Decimal @default(0) @db.Decimal(18, 6)
  sortOrder      Int     @default(0)

  isActive Boolean @default(true)

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jewelry  Jewelry        @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  variants MetalVariant[]

  refHistory MetalRefValueHistory[]

  // ✅ historial valor variante (para búsquedas por metal)
  variantValueHistory MetalVariantValueHistory[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, sortOrder])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model MetalVariant {
  id      String @id @default(cuid())
  metalId String
  name    String
  sku     String

  purity Decimal @db.Decimal(6, 4)

  saleFactor Decimal @default(1.0) @db.Decimal(12, 6)

  isFavorite Boolean @default(false)
  isActive   Boolean @default(true)

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metal  Metal        @relation(fields: [metalId], references: [id], onDelete: Cascade)
  quotes MetalQuote[]

  // ✅ historial valor variante (Opción B PRO)
  valueHistory MetalVariantValueHistory[]

  // ✅ Inventario
  movementLines InventoryMovementLine[]

  // ✅ Stock materializado
  stocks WarehouseStock[]

  @@unique([metalId, sku])
  @@index([metalId])
  @@index([metalId, isActive])
  @@index([metalId, isFavorite])
  @@index([deletedAt])
  @@index([metalId, deletedAt])
}

model MetalQuote {
  id         String @id @default(cuid())
  variantId  String
  currencyId String

  price Decimal @db.Decimal(18, 6)

  effectiveAt DateTime
  createdAt   DateTime @default(now())

  // ✅ NUEVO: quién creó la cotización/snapshot
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  variant  MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  currency Currency     @relation(fields: [currencyId], references: [id], onDelete: Restrict)

  @@index([variantId, effectiveAt])
  @@index([currencyId])
  @@index([createdById])
}

model MetalRefValueHistory {
  id             String   @id @default(cuid())
  jewelryId      String
  metalId        String
  referenceValue Decimal  @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime @default(now())

  createdById String?
  createdBy   User?   @relation("MetalRefHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  metal   Metal   @relation(fields: [metalId], references: [id], onDelete: Cascade)
  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([jewelryId, metalId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model MetalVariantValueHistory {
  id        String @id @default(cuid())
  jewelryId String
  metalId   String
  variantId String

  referenceValue Decimal @db.Decimal(18, 6)
  purity         Decimal @db.Decimal(6, 4)
  saleFactor     Decimal @db.Decimal(12, 6)

  suggestedPrice Decimal @db.Decimal(18, 6)
  finalSalePrice Decimal @db.Decimal(18, 6)

  // fecha para graficar/historial
  effectiveAt DateTime
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   User?   @relation("VariantValueHistoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  jewelry Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal   Metal        @relation(fields: [metalId], references: [id], onDelete: Cascade)
  variant MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([jewelryId, variantId, effectiveAt])
  @@index([variantId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

//////////////////////////////
// ENUMS
//////////////////////////////
enum UserStatus {
  ACTIVE
  PENDING
  BLOCKED
}

enum PermModule {
  USERS_ROLES
  INVENTORY
  MOVEMENTS
  CLIENTS
  SALES
  SUPPLIERS
  PURCHASES
  CURRENCIES
  COMPANY_SETTINGS
  REPORTS
  WAREHOUSES
  PROFILE
}

enum PermAction {
  VIEW
  CREATE
  EDIT
  DELETE
  EXPORT
  ADMIN
}

enum OverrideEffect {
  ALLOW
  DENY
}

//////////////////////////////
// CATÁLOGOS
//////////////////////////////
enum CatalogType {
  IVA_CONDITION
  PHONE_PREFIX
  DOCUMENT_TYPE
  CITY
  PROVINCE
  COUNTRY
}

model CatalogItem {
  id         String      @id @default(cuid())
  jewelryId  String
  type       CatalogType
  label      String
  isActive   Boolean     @default(true)
  sortOrder  Int         @default(0)
  isFavorite Boolean     @default(false)

  // ✅ SOFT DELETE
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, type, label])
  @@index([jewelryId])
  @@index([jewelryId, type, isActive])
  @@index([jewelryId, type, isFavorite])
  @@index([deletedAt])
  @@index([jewelryId, type, deletedAt])
}
