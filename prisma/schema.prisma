  street       String      @default("")
  streetNumber String      @default("")
  floor        String      @default("")
  apartment    String      @default("")
  city         String      @default("")
  province     String      @default("")
  country      String      @default("Argentina")
  postalCode   String      @default("")
  isDefault    Boolean     @default(false) // default para su tipo AddressType
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())

  entity CommercialEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([jewelryId])
  @@index([deletedAt])
}

