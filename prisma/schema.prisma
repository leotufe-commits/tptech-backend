/// ///////////////////////////
/// ///////////////////////////
/// NOTA ARQUITECTURAL: Los comprobantes futuros (facturas, remitos, etc.)
/// guardarán un snapshot propio de la entidad, lista de precios, moneda,
/// condiciones y reglas aplicadas en el momento de su creación.
/// Nunca deben recalcularse leyendo la ficha actual de la entidad.
/// ///////////////////////////
model CommercialEntity {
  id                  String           @id @default(cuid())
  jewelryId           String
  code                String           // CE-0001 — generado una sola vez al crear, nunca cambia
  displayName         String           // calculado en backend: COMPANY=tradeName||companyName, PERSON="Apellido, Nombre"

  entityType          EntityType       @default(PERSON)

  // Roles — al menos uno debe ser true (validado en service)
  isClient            Boolean          @default(false)
  isSupplier          Boolean          @default(false)

  // Datos persona física
  firstName           String           @default("")
  lastName            String           @default("")

  // Datos empresa
  companyName         String           @default("") // Razón social
  tradeName           String           @default("") // Nombre de fantasía

  // Contacto primario (acceso rápido en listados)
  email               String           @default("")
  phone               String           @default("")

  // Fiscal
  documentType        String           @default("")
  documentNumber      String           @default("")
  ivaCondition        String           @default("")

  // Cuenta corriente
  balanceType         BalanceType      @default(UNIFIED)
  creditLimitClient   Decimal?         @db.Decimal(14, 2)
  creditLimitSupplier Decimal?         @db.Decimal(14, 2)

  // Defaults comerciales
  priceListId         String?          // lista de precios habitual (FK a PriceList)
  currencyId          String?          // moneda habitual de facturación (FK a Currency)
  sellerId            String?          // vendedor por defecto (FK a Seller). Tiene prioridad sobre el favorito del sistema en Factura de Venta.
  paymentTerm         String           @default("") // término de pago (ej: "30 días" — catálogo PAYMENT_TERM)
  commercialApplyOn   CommercialApplyOn?   // base de aplicación de impuestos por defecto
  commercialRuleType  CommercialRuleType?  // tipo de beneficio/recargo por defecto (BONUS/SURCHARGE)
  commercialValueType CommercialValueType? // tipo de valor del beneficio/recargo por defecto
  commercialValue     Decimal?         @db.Decimal(14, 4) // valor del beneficio/recargo por defecto

  // Configuración fiscal
  taxExempt           Boolean          @default(false) // true = no se aplican impuestos a esta entidad
  taxApplyOnOverride  TaxApplyOn?      // null = heredar la base del impuesto; valor = sobrescribir para todos sus impuestos

  // Estado y trazabilidad
  isActive            Boolean          @default(true)
  deletedAt           DateTime?
  sourceType          EntitySourceType @default(MANUAL)
  mergedIntoEntityId  String?          // si fue fusionada, referencia al destino (nunca se borra la origen)
  notes               String           @default("")
  avatarUrl           String           @default("")

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  jewelry         Jewelry              @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  priceList       PriceList?           @relation("EntityPriceList", fields: [priceListId], references: [id], onDelete: SetNull)
  currency        Currency?            @relation("EntityCurrency", fields: [currencyId], references: [id], onDelete: SetNull)
  seller          Seller?              @relation("EntityDefaultSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  addresses       EntityAddress[]
  contacts        EntityContact[]
  commercialRules EntityCommercialRule[]
  taxOverrides    EntityTaxOverride[]
  balanceEntries  EntityBalanceEntry[]
  attachments     EntityAttachment[]
  mermaOverrides  EntityMermaOverride[]
  relationsFrom   EntityRelation[]      @relation("RelationFrom")
  relationsTo     EntityRelation[]      @relation("RelationTo")
  mergedFrom           CommercialEntity[]    @relation("EntityMerge")
  mergedInto           CommercialEntity?     @relation("EntityMerge", fields: [mergedIntoEntityId], references: [id], onDelete: SetNull)
  preferredSupplierFor       Article[]              @relation("ArticlePreferredSupplier")
  salesAsClient              Sale[]                 @relation("SaleClient")
  purchasesAsSupplier        Purchase[]             @relation("PurchaseSupplier")
  couponClients              CouponClient[]
  couponRedemptions          CouponRedemption[]     @relation("CouponRedemptionClient")
  purchasePaymentsAsSupplier PurchasePayment[]       @relation("PurchasePaymentSupplier")
  crossSettlementsAsSupplier CrossSettlement[]       @relation("CrossSettlementSupplier")
  receiptsAsCounterparty     Receipt[]               @relation("ReceiptCounterparty")
  currentAccountMovements    CurrentAccountMovement[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isClient, isActive])
  @@index([jewelryId, isSupplier, isActive])
  @@index([jewelryId, displayName])
  @@index([jewelryId, documentNumber])
  @@index([priceListId])
  @@index([currencyId])
  @@index([sellerId])
  @@index([deletedAt])
}

