generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// ///////////////////////////
/// ///////////////////////////
model Jewelry {
  id                         String                     @id @default(cuid())
  name                       String
  firstName                  String
  lastName                   String
  phoneCountry               String
  phoneNumber                String
  street                     String
  number                     String
  city                       String
  province                   String
  postalCode                 String
  country                    String
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  cuit                       String                     @default("")
  email                      String                     @default("")
  ivaCondition               String                     @default("")
  legalName                  String                     @default("")
  logoUrl                    String                     @default("")
  notes                      String                     @default("")
  website                    String                     @default("")
  quickSwitchEnabled         Boolean                    @default(false)
  pinLockEnabled             Boolean                    @default(false)
  pinLockRequireOnUserSwitch Boolean                    @default(false)
  pinLockTimeoutSec          Int                        @default(120)
  defaultMermaPercent        Decimal?                   @db.Decimal(5, 2) // merma global del tenant

  // ── Email branding (por joyería) ──────────────────────────────────────────
  // Bloque 1 — Identidad del correo
  emailEnabled               Boolean                    @default(true)
  emailSenderName            String                     @default("") // "Joyería Pérez" — nombre visible del remitente
  emailLogoUrl               String                     @default("") // URL del logo para correos (vacío = usa logoUrl)
  emailSignature             String                     @default("") // Firma al pie del cuerpo

  // Bloque 2 — Respuesta y contacto
  emailReplyTo               String                     @default("") // Reply-To header
  emailContact               String                     @default("") // email visible al cliente
  emailPhone                 String                     @default("")
  emailWhatsapp              String                     @default("")

  // Bloque 3 — Pie e información comercial
  emailAddressLine           String                     @default("")
  emailBusinessHours         String                     @default("")
  emailWebsite               String                     @default("")
  emailInstagram             String                     @default("")
  emailFooter                String                     @default("") // párrafo de pie del correo
  // ── Fin Email branding ────────────────────────────────────────────────────

  deletedAt                  DateTime?
  auditLogs                  AuditLog[]
  catalogItems               CatalogItem[]
  currencies                 Currency[]
  movements                  InventoryMovement[]
  movementLines              InventoryMovementLine[]
  attachments                JewelryAttachment[]
  metals                     Metal[]
  metalRefHistory            MetalRefValueHistory[]
  variantValueHistory        MetalVariantValueHistory[]
  roles                      Role[]
  users                      User[]
  warehouses                 Warehouse[]
  warehouseStocks            WarehouseStock[]
  articleCategories          ArticleCategory[]
  taxes                      Tax[]
  paymentMethods             PaymentMethod[]
  shippingCarriers           ShippingCarrier[]
  sellers                    Seller[]
  priceLists                 PriceList[]
  attributeDefs              ArticleAttributeDef[]
  commercialEntities         CommercialEntity[]
  articles                   Article[]
  articleMovements           ArticleMovement[]
  sales                      Sale[]
  promotions                 Promotion[]
  quantityDiscounts          QuantityDiscount[]
  labelTemplates             LabelTemplate[]
  printerProfiles            PrinterProfile[]

  @@index([createdAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model JewelryAttachment {
  id        String    @id @default(cuid())
  jewelryId String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  jewelry   Jewelry   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([jewelryId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Warehouse {
  id            String              @id @default(cuid())
  jewelryId     String
  name          String
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  code          String              @default("")
  notes         String              @default("")
  attn          String              @default("")
  city          String              @default("")
  country       String              @default("")
  location      String              @default("")
  number        String              @default("")
  phoneCountry  String              @default("")
  phoneNumber   String              @default("")
  postalCode    String              @default("")
  province      String              @default("")
  street        String              @default("")
  fromMovements InventoryMovement[] @relation("MovementFromWarehouse")
  toMovements   InventoryMovement[] @relation("MovementToWarehouse")
  movements     InventoryMovement[] @relation("MovementWarehouse")
  favoriteUsers    User[]              @relation("UserFavoriteWarehouse")
  jewelry          Jewelry             @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  stocks           WarehouseStock[]
  sellers          SellerWarehouse[]
  shippingCarriers     ShippingCarrier[]   @relation("WarehousePickups")
  articleStock         ArticleStock[]
  articleMovements     ArticleMovement[]   @relation("ArticleMovementWarehouse")
  articleMovementsFrom ArticleMovement[]   @relation("ArticleMovementFrom")
  articleMovementsTo   ArticleMovement[]   @relation("ArticleMovementTo")
  sales                Sale[]              @relation("SaleWarehouse")

  @@index([jewelryId])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model InventoryMovement {
  id              String                  @id @default(cuid())
  jewelryId       String
  kind            InventoryMovementKind
  code            String                  @default("")
  note            String                  @default("")
  effectiveAt     DateTime
  warehouseId     String?
  fromWarehouseId String?
  toWarehouseId   String?
  createdById     String?
  deletedAt       DateTime?
  voidedAt        DateTime?
  voidedNote      String                  @default("")
  voidedById      String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  createdBy       User?                   @relation("MovementCreatedBy", fields: [createdById], references: [id])
  fromWarehouse   Warehouse?              @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  jewelry         Jewelry                 @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse?              @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  voidedBy        User?                   @relation("MovementVoidedBy", fields: [voidedById], references: [id])
  warehouse       Warehouse?              @relation("MovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  lines           InventoryMovementLine[]

  @@index([jewelryId, createdAt])
  @@index([jewelryId, effectiveAt])
  @@index([jewelryId, kind])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([deletedAt])
}

model InventoryMovementLine {
  id         String            @id @default(cuid())
  jewelryId  String
  movementId String
  variantId  String
  grams      Decimal           @db.Decimal(18, 6)
  createdAt  DateTime          @default(now())
  jewelry    Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  movement   InventoryMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  variant    MetalVariant      @relation(fields: [variantId], references: [id])

  @@index([jewelryId, createdAt])
  @@index([movementId])
  @@index([variantId])
}

/// ///////////////////////////
/// ///////////////////////////
model WarehouseStock {
  id          String       @id @default(cuid())
  jewelryId   String
  warehouseId String
  variantId   String
  grams       Decimal      @default(0) @db.Decimal(18, 6)
  pieces      Int          @default(0)
  updatedAt   DateTime     @updatedAt
  jewelry     Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  variant     MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, warehouseId, variantId])
  @@index([jewelryId, warehouseId])
  @@index([warehouseId])
  @@index([variantId])
}

/// ///////////////////////////
/// ///////////////////////////
model User {
  id                         String                     @id @default(cuid())
  email                      String
  password                   String
  name                       String?
  status                     UserStatus                 @default(ACTIVE)
  tokenVersion               Int                        @default(0)
  avatarUrl                  String?
  jewelryId                  String
  favoriteWarehouseId        String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  firstName                  String                     @default("")
  lastName                   String                     @default("")
  city                       String                     @default("")
  country                    String                     @default("")
  documentNumber             String                     @default("")
  documentType               String                     @default("")
  notes                      String                     @default("")
  number                     String                     @default("")
  phoneCountry               String                     @default("")
  phoneNumber                String                     @default("")
  postalCode                 String                     @default("")
  province                   String                     @default("")
  street                     String                     @default("")
  deletedAt                  DateTime?
  quickPinFailedCount        Int                        @default(0)
  quickPinHash               String?
  quickPinLockedUntil        DateTime?
  quickPinUpdatedAt          DateTime?
  quickPinEnabled            Boolean                    @default(false)
  auditLogs                  AuditLog[]
  authTokens                 AuthToken[]
  currencyRatesCreated       CurrencyRate[]             @relation("CurrencyRateCreatedBy")
  movementsCreated           InventoryMovement[]        @relation("MovementCreatedBy")
  movementsVoided            InventoryMovement[]        @relation("MovementVoidedBy")
  metalQuotesCreated         MetalQuote[]
  metalRefHistoryCreated     MetalRefValueHistory[]     @relation("MetalRefHistoryCreatedBy")
  variantValueHistoryCreated MetalVariantValueHistory[] @relation("VariantValueHistoryCreatedBy")
  favoriteWarehouse          Warehouse?                 @relation("UserFavoriteWarehouse", fields: [favoriteWarehouseId], references: [id])
  jewelry                    Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  attachments                UserAttachment[]
  permissionOverrides        UserPermissionOverride[]
  roles                      UserRole[]
  seller                     Seller?
  articleMovementsCreated    ArticleMovement[]          @relation("ArticleMovementCreatedBy")
  articleMovementsVoided     ArticleMovement[]          @relation("ArticleMovementVoidedBy")
  salesCreated               Sale[]                     @relation("SaleCreatedBy")
  salesConfirmed             Sale[]                     @relation("SaleConfirmedBy")
  salesCancelled             Sale[]                     @relation("SaleCancelledBy")

  @@unique([jewelryId, email])
  @@index([jewelryId])
  @@index([jewelryId, status])
  @@index([favoriteWarehouseId])
  @@index([jewelryId, deletedAt])
  @@index([quickPinUpdatedAt])
  @@index([quickPinEnabled])
}

/// ///////////////////////////
/// ///////////////////////////
model UserAttachment {
  id        String    @id @default(cuid())
  userId    String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model AuthToken {
  id            String    @id @default(cuid())
  type          String    @default("reset")
  jti           String    @unique
  userId        String
  emailSnapshot String    @default("")
  ip            String?
  userAgent     String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type, expiresAt])
  @@index([usedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Role {
  id          String           @id @default(cuid())
  jewelryId   String
  name        String
  isSystem    Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  displayName String?
  jewelry     Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, deletedAt])
}

model Permission {
  id        String                   @id @default(cuid())
  module    PermModule
  action    PermAction
  createdAt DateTime                 @default(now())
  roles     RolePermission[]
  overrides UserPermissionOverride[]

  @@unique([module, action])
  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserPermissionOverride {
  id           String         @id @default(cuid())
  userId       String
  permissionId String
  effect       OverrideEffect
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

/// ///////////////////////////
/// ///////////////////////////
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String
  success   Boolean
  userId    String?
  jewelryId String?
  ip        String?
  userAgent String?
  meta      Json?
  jewelry   Jewelry? @relation(fields: [jewelryId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([success])
  @@index([jewelryId, createdAt])
  @@index([userId, createdAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Currency {
  id        String         @id @default(cuid())
  jewelryId String
  code      String
  name      String
  symbol    String
  isBase    Boolean        @default(false)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  jewelry        Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  rates          CurrencyRate[]
  quotes         MetalQuote[]
  entityDefaults CommercialEntity[] @relation("EntityCurrency")
  costLines      ArticleCostLine[]  @relation("CostLineCurrency")

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isBase])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model CurrencyRate {
  id          String   @id @default(cuid())
  currencyId  String
  rate        Decimal  @db.Decimal(18, 6)
  effectiveAt DateTime
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("CurrencyRateCreatedBy", fields: [createdById], references: [id])
  currency    Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@index([currencyId, effectiveAt])
  @@index([createdById])
}

/// ///////////////////////////
/// ///////////////////////////
model Metal {
  id                  String                     @id @default(cuid())
  jewelryId           String
  name                String
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  symbol              String                     @default("")
  referenceValue      Decimal                    @default(0) @db.Decimal(18, 6)
  sortOrder           Int                        @default(0)
  deletedAt           DateTime?
  jewelry             Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  refHistory          MetalRefValueHistory[]
  variants            MetalVariant[]
  variantValueHistory MetalVariantValueHistory[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, sortOrder])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model MetalVariant {
  id            String                     @id @default(cuid())
  metalId       String
  name          String
  sku           String
  purity        Decimal                    @db.Decimal(6, 4)
  isFavorite    Boolean                    @default(false)
  isActive      Boolean                    @default(true)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  saleFactor    Decimal                    @default(1.0) @db.Decimal(12, 6)
  deletedAt     DateTime?
  movementLines InventoryMovementLine[]
  quotes        MetalQuote[]
  metal         Metal                      @relation(fields: [metalId], references: [id], onDelete: Cascade)
  valueHistory  MetalVariantValueHistory[]
  stocks        WarehouseStock[]
  compositions   ArticleMetalComposition[]
  mermaOverrides EntityMermaOverride[]
  costLines      ArticleCostLine[]         @relation("CostLineMetalVariant")

  @@unique([metalId, sku])
  @@index([metalId])
  @@index([metalId, isActive])
  @@index([metalId, isFavorite])
  @@index([deletedAt])
  @@index([metalId, deletedAt])
}

model MetalQuote {
  id          String       @id @default(cuid())
  variantId   String
  currencyId  String
  effectiveAt DateTime
  createdAt   DateTime     @default(now())
  createdById String?
  price       Decimal      @db.Decimal(18, 6)
  createdBy   User?        @relation(fields: [createdById], references: [id])
  currency    Currency     @relation(fields: [currencyId], references: [id])
  variant     MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, effectiveAt])
  @@index([variantId, currencyId, effectiveAt])
  @@index([currencyId])
  @@index([createdById])
}

model MetalRefValueHistory {
  id             String   @id @default(cuid())
  jewelryId      String
  metalId        String
  referenceValue Decimal  @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime @default(now())
  createdById    String?
  createdBy      User?    @relation("MetalRefHistoryCreatedBy", fields: [createdById], references: [id])
  jewelry        Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal          Metal    @relation(fields: [metalId], references: [id], onDelete: Cascade)

  @@index([jewelryId, metalId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model MetalVariantValueHistory {
  id             String       @id @default(cuid())
  jewelryId      String
  metalId        String
  variantId      String
  referenceValue Decimal      @db.Decimal(18, 6)
  purity         Decimal      @db.Decimal(6, 4)
  saleFactor     Decimal      @db.Decimal(12, 6)
  finalSalePrice Decimal      @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime     @default(now())
  createdById    String?
  createdBy      User?        @relation("VariantValueHistoryCreatedBy", fields: [createdById], references: [id])
  jewelry        Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal          Metal        @relation(fields: [metalId], references: [id], onDelete: Cascade)
  variant        MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([jewelryId, variantId, effectiveAt])
  @@index([variantId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model CatalogItem {
  id         String      @id @default(cuid())
  jewelryId  String
  type       CatalogType
  label      String
  isActive   Boolean     @default(true)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  isFavorite Boolean     @default(false)
  isSystem   Boolean     @default(false)
  deletedAt  DateTime?
  jewelry    Jewelry     @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, type, label])
  @@index([jewelryId])
  @@index([jewelryId, type, isActive])
  @@index([jewelryId, type, isFavorite])
  @@index([deletedAt])
  @@index([jewelryId, type, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleCategory {
  id                 String    @id @default(cuid())
  jewelryId          String
  parentId           String?
  defaultPriceListId String?
  name               String
  description        String    @default("")
  imageUrl           String    @default("")
  mermaPercent       Decimal?  @db.Decimal(5, 2)  // merma % heredada por los artículos de esta categoría
  sortOrder          Int       @default(0)
  isActive           Boolean   @default(true)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  jewelry          Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  parent           ArticleCategory?           @relation("CategoryTree", fields: [parentId], references: [id])
  children         ArticleCategory[]          @relation("CategoryTree")
  priceLists       PriceList[]                @relation("CategoryPriceLists")
  defaultPriceList PriceList?                 @relation("DefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
  attributes       ArticleCategoryAttribute[]
  articles         Article[]
  promotionCategories PromotionCategory[]     @relation("CategoryPromotions")
  quantityDiscounts   QuantityDiscount[]      @relation("CategoryQuantityDiscounts")

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([parentId])
  @@index([defaultPriceListId])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleCategoryAttribute {
  id             String    @id @default(cuid())
  jewelryId      String
  categoryId     String
  definitionId   String
  isRequired     Boolean   @default(false)
  isActive       Boolean   @default(true)
  isFilterable   Boolean   @default(true)
  isVariantAxis  Boolean   @default(false)
  inheritToChild Boolean   @default(true)
  sortOrder      Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  category        ArticleCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  definition      ArticleAttributeDef   @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  articleValues   ArticleAttributeValue[]
  variantValues   ArticleVariantAttributeValue[]

  @@index([jewelryId])
  @@index([categoryId])
  @@index([definitionId])
  @@index([categoryId, isActive])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleAttributeDef {
  id           String                     @id @default(cuid())
  jewelryId    String
  name         String
  code         String                     @default("")
  inputType    CategoryAttributeInputType
  helpText     String                     @default("")
  unit         String                     @default("")
  defaultValue String                     @default("")
  isActive     Boolean                    @default(true)
  deletedAt    DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  jewelry     Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  options     ArticleAttributeDefOption[]
  assignments ArticleCategoryAttribute[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleAttributeDefOption {
  id            String   @id @default(cuid())
  definitionId  String
  label         String
  value         String
  colorHex      String   @default("")
  codeExtension String   @default("") // extensión de código para generar SKU de variante (ej. "A" → A000A)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  definition ArticleAttributeDef @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@index([definitionId, isActive])
}

/// ///////////////////////////
/// ///////////////////////////
model Tax {
  id              String             @id @default(cuid())
  jewelryId       String
  name            String
  code            String             @default("")
  taxType         TaxType            @default(OTHER)
  calculationType TaxCalculationType @default(PERCENTAGE)
  rate            Decimal?           @db.Decimal(10, 4)
  fixedAmount     Decimal?           @db.Decimal(18, 2)
  applyOn         TaxApplyOn         @default(TOTAL)
  includedInPrice Boolean            @default(false)
  validFrom       DateTime?
  validTo         DateTime?
  isActive        Boolean            @default(true)
  allowDocumentOverride Boolean            @default(false) // si true, el comprobante puede excepcionarlo con auditoría
  isFavorite            Boolean            @default(false)
  isSystem              Boolean            @default(false)
  sortOrder             Int                @default(0)
  notes                 String             @default("")
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

