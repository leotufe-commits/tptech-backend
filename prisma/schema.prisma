generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// ///////////////////////////
/// ///////////////////////////
model Jewelry {
  id                         String   @id @default(cuid())
  name                       String
  legalName                  String   @default("")
  firstName                  String
  lastName                   String
  phoneCountry               String
  phoneNumber                String
  street                     String
  number                     String
  floor                      String   @default("")
  apartment                  String   @default("")
  city                       String
  province                   String
  postalCode                 String
  country                    String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  cuit                       String   @default("")
  email                      String   @default("")
  ivaCondition               String   @default("")
  logoUrl                    String   @default("")
  notes                      String   @default("")
  website                    String   @default("")
  quickSwitchEnabled         Boolean  @default(false)
  pinLockEnabled             Boolean  @default(false)
  pinLockRequireOnUserSwitch Boolean  @default(false)
  pinLockTimeoutSec          Int      @default(120)
  defaultMermaPercent        Decimal? @db.Decimal(5, 2) // merma global del tenant

  // ── Política de alertas de precio ─────────────────────────────────────────
  pricingLowMarginWarningPercent  Decimal? @db.Decimal(10, 4)
  pricingLowMarginBlockPercent    Decimal? @db.Decimal(10, 4)
  pricingBlockLossSale            Boolean  @default(false)
  pricingBlockZeroOrNegativePrice Boolean  @default(true)
  pricingBlockPartialData         Boolean  @default(false)

  // ── Redondeo por comprobante (Etapa 1B — UNIFIED / BREAKDOWN / BOTH) ────
  // Cuando `documentRoundingEnabled = true`, computeSaleDocumentTotals aplica
  // un redondeo final sobre el documento. El `scope` decide cómo:
  //   · UNIFIED   → solo redondea el `total` final (legacy / default).
  //   · BREAKDOWN → redondea los subtotales metal y hechura por separado y
  //                 reflejan el delta combinado en el `total`.
  //   · BOTH      → BREAKDOWN primero, luego UNIFIED sobre el total resultante
  //                 (cascada controlada con guard anti doble-redondeo).
  // Si está activo, las listas con `roundingApplyOn = NET | TOTAL` se ignoran
  // para evitar doble redondeo (ver previewSale/confirmSale).
  // NO afecta líneas individuales, NO afecta impuestos por línea.
  documentRoundingEnabled            Boolean                 @default(false)
  // Configuración UNIFIED (usada cuando scope = UNIFIED o BOTH).
  documentRoundingMode               RoundingMode            @default(NONE)
  documentRoundingDirection          RoundingDirection       @default(NEAREST)
  // Etapa 1B — Scope + configuración BREAKDOWN.
  // Metal y hechura tienen pares modo/dirección INDEPENDIENTES (mismo patrón
  // que `PriceList.roundingMode*` / `roundingMode*Hechura`). Esto permite,
  // por ejemplo, redondear metal a la decena y hechura al entero — caso
  // habitual cuando el componente metálico maneja órdenes de magnitud
  // distintas al de hechura.
  documentRoundingScope              DocumentRoundingScope   @default(UNIFIED)
  documentRoundingModeMetal          RoundingMode            @default(NONE)
  documentRoundingDirectionMetal     RoundingDirection       @default(NEAREST)
  documentRoundingModeHechura        RoundingMode            @default(NONE)
  documentRoundingDirectionHechura   RoundingDirection       @default(NEAREST)

  // ── Etapa D2 — Dominio de redondeo del metal en BREAKDOWN ────────────────
  // POLICY §R-Rounding-13. Discriminador excluyente entre:
  //   · MONETARY (default, back-compat): el redondeo BREAKDOWN.metal opera
  //     sobre `metalSaleSubtotal` $ — comportamiento actual.
  //   · PHYSICAL: el redondeo BREAKDOWN.metal opera sobre gramos por metal
  //     padre vía `lib/document-physical-rounding.ts`. Su monetaryEquivalent
  //     impacta Sale.total. Etapa D3 lo integrará como capa 16 — runtime
  //     todavía NO usa este campo.
  //
  // Default MONETARY garantiza que todos los tenants existentes siguen
  // igual sin migración de datos.
  documentRoundingMetalDomain        DocumentRoundingMetalDomain @default(MONETARY)

  // ── Etapa D2 — Configuración de redondeo físico de gramos por metal padre ─
  // Shape JSON esperado (validado por `lib/document-physical-rounding-config.ts`):
  //   {
  //     "byMetalParentId": {
  //       "<metalParentId>": { "mode": "INTEGER", "direction": "NEAREST" }
  //     },
  //     "fallback": { "mode": "NONE", "direction": "NEAREST" }
  //   }
  //
  // `null` = sin config; cuando domain=PHYSICAL, el helper trata cada metal
  // como `NO_CONFIG` y emite el fallback correspondiente.
  // Solo se consume cuando documentRoundingMetalDomain = PHYSICAL.
  // Etapa D3 lo conectará al motor — runtime D2 NO lo lee.
  documentPhysicalRoundingConfig     Json?

  // ── Balance Mode (POLICY.md §11 — Fase 3B.4) ─────────────────────────────
  // Default global del tenant. Última red de la prioridad R11.4 antes del
  // fallback hardcodeado UNIFIED. NO se aplica en runtime aún (3B.5).
  defaultBalanceMode BalanceMode @default(UNIFIED)

  // ── Email branding (por joyería) ──────────────────────────────────────────
  // Bloque 1 — Identidad del correo
  emailEnabled    Boolean @default(true)
  emailSenderName String  @default("") // "Joyería Pérez" — nombre visible del remitente
  emailLogoUrl    String  @default("") // URL del logo para correos (vacío = usa logoUrl)
  emailSignature  String  @default("") // Firma al pie del cuerpo

  // Bloque 2 — Respuesta y contacto
  emailReplyTo  String @default("") // Reply-To header
  emailContact  String @default("") // email visible al cliente
  emailPhone    String @default("")
  emailWhatsapp String @default("")

  // Bloque 3 — Pie e información comercial
  emailAddressLine   String @default("")
  emailBusinessHours String @default("")
  emailWebsite       String @default("")
  emailInstagram     String @default("")
  emailFooter        String @default("") // párrafo de pie del correo
  // ── Fin Email branding ────────────────────────────────────────────────────

  // ── Formatos de campo ─────────────────────────────────────────────────────
  phoneFormat    String @default("raw") // raw | national_ar | intl_ar | intl_ar_mobile
  documentFormat String @default("raw") // raw | cuit_cuil | dni | digits_only
  // Formato numérico visual por tenant. JSON: { region, custom:{thousands,decimal}, presets:{...} }.
  // SOLO display/input — la DB y el pricing-engine siguen usando números puros.
  numberFormat   Json?

  deletedAt                   DateTime?
  auditLogs                   AuditLog[]
  catalogItems                CatalogItem[]
  currencies                  Currency[]
  movements                   InventoryMovement[]
  movementLines               InventoryMovementLine[]
  attachments                 JewelryAttachment[]
  metals                      Metal[]
  metalRefHistory             MetalRefValueHistory[]
  variantValueHistory         MetalVariantValueHistory[]
  roles                       Role[]
  users                       User[]
  warehouses                  Warehouse[]
  warehouseStocks             WarehouseStock[]
  articleCategories           ArticleCategory[]
  taxes                       Tax[]
  paymentMethods              PaymentMethod[]
  shippingCarriers            ShippingCarrier[]
  sellers                     Seller[]
  priceLists                  PriceList[]
  salesChannels               SalesChannel[]
  attributeDefs               ArticleAttributeDef[]
  commercialEntities          CommercialEntity[]
  articles                    Article[]
  articleMovements            ArticleMovement[]
  sales                       Sale[]
  promotions                  Promotion[]
  quantityDiscounts           QuantityDiscount[]
  labelTemplates              LabelTemplate[]
  printerProfiles             PrinterProfile[]
  purchases                   Purchase[]
  purchasePayments            PurchasePayment[]
  articleGroups               ArticleGroup[]
  documentTemplates           DocumentTemplate[]
  importBatches               ImportBatch[]
  coupons                     Coupon[]
  couponBrands                CouponBrand[]
  units                       Unit[]
  receiptSeries               ReceiptSeries[]
  receipts                    Receipt[]
  receiptLines                ReceiptLine[]
  currentAccountMovements     CurrentAccountMovement[]
  accountMovementMetalEntries AccountMovementMetalEntry[]

  @@index([createdAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model JewelryAttachment {
  id        String    @id @default(cuid())
  jewelryId String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  jewelry   Jewelry   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([jewelryId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Warehouse {
  id                   String                @id @default(cuid())
  jewelryId            String
  name                 String
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  code                 String                @default("")
  notes                String                @default("")
  attn                 String                @default("")
  city                 String                @default("")
  country              String                @default("")
  location             String                @default("")
  number               String                @default("")
  phoneCountry         String                @default("")
  phoneNumber          String                @default("")
  postalCode           String                @default("")
  province             String                @default("")
  street               String                @default("")
  email                String                @default("")
  floor                String                @default("")
  apartment            String                @default("")
  fromMovements        InventoryMovement[]   @relation("MovementFromWarehouse")
  toMovements          InventoryMovement[]   @relation("MovementToWarehouse")
  movements            InventoryMovement[]   @relation("MovementWarehouse")
  favoriteUsers        User[]                @relation("UserFavoriteWarehouse")
  jewelry              Jewelry               @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  stocks               WarehouseStock[]
  sellers              SellerWarehouse[]
  shippingCarriers     ShippingCarrier[]     @relation("WarehousePickups")
  articleStock         ArticleStock[]
  articleMovements     ArticleMovement[]     @relation("ArticleMovementWarehouse")
  articleMovementsFrom ArticleMovement[]     @relation("ArticleMovementFrom")
  articleMovementsTo   ArticleMovement[]     @relation("ArticleMovementTo")
  sales                Sale[]                @relation("SaleWarehouse")
  attachments          WarehouseAttachment[]

  @@index([jewelryId])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model WarehouseAttachment {
  id          String    @id @default(cuid())
  warehouseId String
  jewelryId   String
  filename    String
  url         String
  mimeType    String    @default("")
  size        Int       @default(0)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([warehouseId])
  @@index([jewelryId])
  @@index([deletedAt])
}

model InventoryMovement {
  id              String                  @id @default(cuid())
  jewelryId       String
  kind            InventoryMovementKind
  code            String                  @default("")
  note            String                  @default("")
  effectiveAt     DateTime
  warehouseId     String?
  fromWarehouseId String?
  toWarehouseId   String?
  createdById     String?
  deletedAt       DateTime?
  voidedAt        DateTime?
  voidedNote      String                  @default("")
  voidedById      String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  createdBy       User?                   @relation("MovementCreatedBy", fields: [createdById], references: [id])
  fromWarehouse   Warehouse?              @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  jewelry         Jewelry                 @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse?              @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  voidedBy        User?                   @relation("MovementVoidedBy", fields: [voidedById], references: [id])
  warehouse       Warehouse?              @relation("MovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  lines           InventoryMovementLine[]

  @@index([jewelryId, createdAt])
  @@index([jewelryId, effectiveAt])
  @@index([jewelryId, kind])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([deletedAt])
}

model InventoryMovementLine {
  id         String            @id @default(cuid())
  jewelryId  String
  movementId String
  variantId  String
  grams      Decimal           @db.Decimal(18, 6)
  snapshot   Json? // snapshot histórico: { metalVariantName, metalName }
  createdAt  DateTime          @default(now())
  jewelry    Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  movement   InventoryMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  variant    MetalVariant      @relation(fields: [variantId], references: [id])

  @@index([jewelryId, createdAt])
  @@index([movementId])
  @@index([variantId])
}

/// ///////////////////////////
/// ///////////////////////////
model WarehouseStock {
  id          String       @id @default(cuid())
  jewelryId   String
  warehouseId String
  variantId   String
  grams       Decimal      @default(0) @db.Decimal(18, 6)
  pieces      Int          @default(0)
  updatedAt   DateTime     @updatedAt
  jewelry     Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  variant     MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, warehouseId, variantId])
  @@index([jewelryId, warehouseId])
  @@index([warehouseId])
  @@index([variantId])
}

/// ///////////////////////////
/// ///////////////////////////
model User {
  id                         String                     @id @default(cuid())
  email                      String
  password                   String
  name                       String?
  status                     UserStatus                 @default(ACTIVE)
  tokenVersion               Int                        @default(0)
  avatarUrl                  String?
  jewelryId                  String
  favoriteWarehouseId        String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  firstName                  String                     @default("")
  lastName                   String                     @default("")
  city                       String                     @default("")
  country                    String                     @default("")
  documentNumber             String                     @default("")
  documentType               String                     @default("")
  notes                      String                     @default("")
  number                     String                     @default("")
  floor                      String                     @default("")
  apartment                  String                     @default("")
  phoneCountry               String                     @default("")
  phoneNumber                String                     @default("")
  postalCode                 String                     @default("")
  province                   String                     @default("")
  street                     String                     @default("")
  deletedAt                  DateTime?
  quickPinFailedCount        Int                        @default(0)
  quickPinHash               String?
  quickPinLockedUntil        DateTime?
  quickPinUpdatedAt          DateTime?
  quickPinEnabled            Boolean                    @default(false)
  themePreference            String?
  auditLogs                  AuditLog[]
  authTokens                 AuthToken[]
  currencyRatesCreated       CurrencyRate[]             @relation("CurrencyRateCreatedBy")
  movementsCreated           InventoryMovement[]        @relation("MovementCreatedBy")
  movementsVoided            InventoryMovement[]        @relation("MovementVoidedBy")
  metalQuotesCreated         MetalQuote[]
  metalRefHistoryCreated     MetalRefValueHistory[]     @relation("MetalRefHistoryCreatedBy")
  variantValueHistoryCreated MetalVariantValueHistory[] @relation("VariantValueHistoryCreatedBy")
  favoriteWarehouse          Warehouse?                 @relation("UserFavoriteWarehouse", fields: [favoriteWarehouseId], references: [id])
  jewelry                    Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  attachments                UserAttachment[]
  permissionOverrides        UserPermissionOverride[]
  roles                      UserRole[]
  seller                     Seller?
  articleMovementsCreated    ArticleMovement[]          @relation("ArticleMovementCreatedBy")
  articleMovementsVoided     ArticleMovement[]          @relation("ArticleMovementVoidedBy")
  salesCreated               Sale[]                     @relation("SaleCreatedBy")
  salesConfirmed             Sale[]                     @relation("SaleConfirmedBy")
  salesCancelled             Sale[]                     @relation("SaleCancelledBy")
  purchasesCreated           Purchase[]                 @relation("PurchaseCreatedBy")
  purchasesConfirmed         Purchase[]                 @relation("PurchaseConfirmedBy")
  purchasesCancelled         Purchase[]                 @relation("PurchaseCancelledBy")
  purchasePaymentsCreated    PurchasePayment[]          @relation("PurchasePaymentCreatedBy")
  crossSettlementsCreated    CrossSettlement[]          @relation("CrossSettlementCreatedBy")
  crossSettlementsVoided     CrossSettlement[]          @relation("CrossSettlementVoidedBy")
  importBatches              ImportBatch[]              @relation("ImportBatchCreatedBy")
  receiptsIssued             Receipt[]                  @relation("ReceiptIssuedBy")
  receiptsVoided             Receipt[]                  @relation("ReceiptVoidedBy")

  @@unique([jewelryId, email])
  @@index([jewelryId])
  @@index([jewelryId, status])
  @@index([favoriteWarehouseId])
  @@index([jewelryId, deletedAt])
  @@index([quickPinUpdatedAt])
  @@index([quickPinEnabled])
}

/// ///////////////////////////
/// ///////////////////////////
/// Contexto de la preferencia. Fase 1: solo SALES_INVOICE.
/// Pensado para crecer a otros documentos/módulos a futuro
/// (PURCHASE_INVOICE, etc.) sin cambiar el modelo.
enum UserPreferenceScope {
  SALES_INVOICE
}

/// Preferencias por usuario, scopeadas por contexto (`scope`).
/// Solo precarga campos de UI: NUNCA afecta pricing-engine ni cálculos.
/// Modelo sin relaciones Prisma a propósito (columnas planas): la
/// pertenencia de cada default al `jewelryId` del usuario se valida en
/// `user-preferences.service.ts`. Mantiene la migración mínima y sin drift.
/// `User.favoriteWarehouseId` queda legacy tras el backfill (no se borra aún).
model UserPreference {
  id        String              @id @default(cuid())
  jewelryId String
  userId    String
  scope     UserPreferenceScope

  defaultWarehouseId String?
  defaultSellerId    String?
  defaultPriceListId String?
  defaultChannelId   String?
  defaultCurrencyId  String?

  /// Tipo predeterminado del Descuento global del comprobante:
  ///   · "PERCENT" → el operador prefiere porcentaje (default histórico).
  ///   · "AMOUNT"  → el operador prefiere monto fijo.
  ///   · null      → sin preferencia → fallback "PERCENT" en frontend.
  /// Solo precarga UI (igual que los otros defaults). NO afecta pricing-engine.
  defaultGlobalDiscountType String?

  /// Layout personalizable del modal de Factura de ventas. JSON opaco
  /// para el backend (solo persiste y devuelve tal cual). El frontend
  /// valida el shape con `reconcileLayout` y aplica el default si es
  /// inválido. Forma esperada (Fase 1):
  ///   { version: 1, cards: [{ id, slot, order, width }, ...] }
  /// `null` → usar layout default del frontend. Solo afecta UI.
  invoiceLayoutConfig Json?

  /// Plantilla de vista preferida del usuario para la Factura de ventas.
  /// Valores: "BALANCED" (default) | "CLASSIC" | "COMPACT" | "FINANCIAL".
  /// `null` → usar default "BALANCED" del frontend. Es solo precarga UI:
  /// configura layout base, jerarquía, densidad. NO afecta pricing-engine
  /// ni cálculos. Convive con `invoiceLayoutConfig`: el preset define la
  /// base, los drags/resizes manuales del usuario tienen prioridad encima.
  preferredInvoiceViewPreset String?

  /// Configuraciones finas de UI del modal de Factura de ventas (UX.20).
  /// JSON opaco para el backend (solo persiste y devuelve tal cual). El
  /// frontend valida con `resolveInvoiceUiPreferences` y aplica defaults
  /// si es inválido. Forma esperada (Fase 1):
  ///   {
  ///     density: "COMPACT" | "NORMAL" | "COMFORTABLE",
  ///     stickyActions: boolean,
  ///     ...futuros toggles
  ///   }
  /// SEPARADO de `preferredInvoiceViewPreset` (presets) y de
  /// `invoiceLayoutConfig` (drag/resize) — son tres dimensiones
  /// ortogonales. `null` → frontend cae a defaults. NO afecta cálculos.
  invoiceUiPreferences Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, scope])
  @@index([jewelryId])
  @@index([userId])
}

/// ///////////////////////////
/// ///////////////////////////
model UserAttachment {
  id        String    @id @default(cuid())
  userId    String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model AuthToken {
  id            String    @id @default(cuid())
  type          String    @default("reset")
  jti           String    @unique
  userId        String
  emailSnapshot String    @default("")
  ip            String?
  userAgent     String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type, expiresAt])
  @@index([usedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Role {
  id          String           @id @default(cuid())
  jewelryId   String
  name        String
  isSystem    Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  displayName String?
  jewelry     Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, deletedAt])
}

model Permission {
  id        String                   @id @default(cuid())
  module    PermModule
  action    PermAction
  createdAt DateTime                 @default(now())
  roles     RolePermission[]
  overrides UserPermissionOverride[]

  @@unique([module, action])
  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserPermissionOverride {
  id           String         @id @default(cuid())
  userId       String
  permissionId String
  effect       OverrideEffect
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

/// ///////////////////////////
/// ///////////////////////////
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String
  success   Boolean
  userId    String?
  jewelryId String?
  ip        String?
  userAgent String?
  meta      Json?
  jewelry   Jewelry? @relation(fields: [jewelryId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([success])
  @@index([jewelryId, createdAt])
  @@index([userId, createdAt])
}

/// ///////////////////////////
/// ///////////////////////////
model Currency {
  id             String             @id @default(cuid())
  jewelryId      String
  code           String
  name           String
  symbol         String
  isBase         Boolean            @default(false)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  jewelry        Jewelry            @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  rates          CurrencyRate[]
  quotes         MetalQuote[]
  entityDefaults CommercialEntity[] @relation("EntityCurrency")
  costLines      ArticleCostLine[]  @relation("CostLineCurrency")

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isBase])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model CurrencyRate {
  id          String   @id @default(cuid())
  currencyId  String
  rate        Decimal  @db.Decimal(18, 6)
  effectiveAt DateTime
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("CurrencyRateCreatedBy", fields: [createdById], references: [id])
  currency    Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@index([currencyId, effectiveAt])
  @@index([createdById])
}

/// ///////////////////////////
/// ///////////////////////////
model Metal {
  id                  String                     @id @default(cuid())
  jewelryId           String
  name                String
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  symbol              String                     @default("")
  referenceValue      Decimal                    @default(0) @db.Decimal(18, 6)
  sortOrder           Int                        @default(0)
  deletedAt           DateTime?
  jewelry             Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  refHistory          MetalRefValueHistory[]
  variants            MetalVariant[]
  variantValueHistory MetalVariantValueHistory[]

  @@unique([jewelryId, name])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, sortOrder])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

model MetalVariant {
  id              String                     @id @default(cuid())
  metalId         String
  name            String
  sku             String
  purity          Decimal                    @db.Decimal(6, 4)
  isFavorite      Boolean                    @default(false)
  isActive        Boolean                    @default(true)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  saleFactor      Decimal                    @default(1.0) @db.Decimal(12, 6)
  deletedAt       DateTime?
  movementLines   InventoryMovementLine[]
  quotes          MetalQuote[]
  metal           Metal                      @relation(fields: [metalId], references: [id], onDelete: Cascade)
  valueHistory    MetalVariantValueHistory[]
  stocks          WarehouseStock[]
  mermaOverrides  EntityMermaOverride[]
  costLines       ArticleCostLine[]          @relation("CostLineMetalVariant")
  promotionScopes PromotionMetalVariant[]    @relation("PromotionMetalVariant")
  couponScopes    CouponMetalVariant[]       @relation("CouponMetalVariant")

  @@unique([metalId, sku])
  @@index([metalId])
  @@index([metalId, isActive])
  @@index([metalId, isFavorite])
  @@index([deletedAt])
  @@index([metalId, deletedAt])
}

model MetalQuote {
  id          String       @id @default(cuid())
  variantId   String
  currencyId  String
  effectiveAt DateTime
  createdAt   DateTime     @default(now())
  createdById String?
  price       Decimal      @db.Decimal(18, 6)
  createdBy   User?        @relation(fields: [createdById], references: [id])
  currency    Currency     @relation(fields: [currencyId], references: [id])
  variant     MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, effectiveAt])
  @@index([variantId, currencyId, effectiveAt])
  @@index([currencyId])
  @@index([createdById])
}

model MetalRefValueHistory {
  id             String   @id @default(cuid())
  jewelryId      String
  metalId        String
  referenceValue Decimal  @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime @default(now())
  createdById    String?
  createdBy      User?    @relation("MetalRefHistoryCreatedBy", fields: [createdById], references: [id])
  jewelry        Jewelry  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal          Metal    @relation(fields: [metalId], references: [id], onDelete: Cascade)

  @@index([jewelryId, metalId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model MetalVariantValueHistory {
  id             String       @id @default(cuid())
  jewelryId      String
  metalId        String
  variantId      String
  referenceValue Decimal      @db.Decimal(18, 6)
  purity         Decimal      @db.Decimal(6, 4)
  saleFactor     Decimal      @db.Decimal(12, 6)
  finalSalePrice Decimal      @db.Decimal(18, 6)
  effectiveAt    DateTime
  createdAt      DateTime     @default(now())
  createdById    String?
  createdBy      User?        @relation("VariantValueHistoryCreatedBy", fields: [createdById], references: [id])
  jewelry        Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  metal          Metal        @relation(fields: [metalId], references: [id], onDelete: Cascade)
  variant        MetalVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([jewelryId, variantId, effectiveAt])
  @@index([variantId, effectiveAt])
  @@index([metalId, effectiveAt])
  @@index([createdById])
}

model CatalogItem {
  id         String      @id @default(cuid())
  jewelryId  String
  type       CatalogType
  label      String
  isActive   Boolean     @default(true)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  isFavorite Boolean     @default(false)
  isSystem   Boolean     @default(false)
  deletedAt  DateTime?
  jewelry    Jewelry     @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, type, label])
  @@index([jewelryId])
  @@index([jewelryId, type, isActive])
  @@index([jewelryId, type, isFavorite])
  @@index([deletedAt])
  @@index([jewelryId, type, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleCategory {
  id                 String    @id @default(cuid())
  jewelryId          String
  parentId           String?
  defaultPriceListId String?
  name               String
  description        String    @default("")
  imageUrl           String    @default("")
  mermaPercent       Decimal?  @db.Decimal(5, 2) // merma % heredada por los artículos de esta categoría
  sortOrder          Int       @default(0)
  isActive           Boolean   @default(true)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  jewelry             Jewelry                    @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  parent              ArticleCategory?           @relation("CategoryTree", fields: [parentId], references: [id])
  children            ArticleCategory[]          @relation("CategoryTree")
  priceLists          PriceList[]                @relation("CategoryPriceLists")
  defaultPriceList    PriceList?                 @relation("DefaultPriceList", fields: [defaultPriceListId], references: [id], onDelete: SetNull)
  attributes          ArticleCategoryAttribute[]
  articles            Article[]
  promotionCategories PromotionCategory[]        @relation("CategoryPromotions")
  quantityDiscounts   QuantityDiscount[]         @relation("CategoryQuantityDiscounts")
  couponCategories    CouponCategory[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([parentId])
  @@index([defaultPriceListId])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleCategoryAttribute {
  id             String    @id @default(cuid())
  jewelryId      String
  categoryId     String
  definitionId   String
  isRequired     Boolean   @default(false)
  isActive       Boolean   @default(true)
  isFilterable   Boolean   @default(true)
  isVariantAxis  Boolean   @default(false)
  inheritToChild Boolean   @default(true)
  sortOrder      Int       @default(0)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  category      ArticleCategory                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  definition    ArticleAttributeDef            @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  articleValues ArticleAttributeValue[]
  variantValues ArticleVariantAttributeValue[]

  @@index([jewelryId])
  @@index([categoryId])
  @@index([definitionId])
  @@index([categoryId, isActive])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleAttributeDef {
  id           String                     @id @default(cuid())
  jewelryId    String
  name         String
  code         String                     @default("")
  inputType    CategoryAttributeInputType
  helpText     String                     @default("")
  unit         String                     @default("")
  defaultValue String                     @default("")
  isActive     Boolean                    @default(true)
  sortOrder    Int                        @default(0)
  deletedAt    DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  jewelry     Jewelry                     @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  options     ArticleAttributeDefOption[]
  assignments ArticleCategoryAttribute[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([deletedAt])
  @@index([jewelryId, deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model ArticleAttributeDefOption {
  id            String   @id @default(cuid())
  definitionId  String
  label         String
  value         String
  colorHex      String   @default("")
  codeExtension String   @default("") // extensión de código para generar SKU de variante (ej. "A" → A000A)
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  definition ArticleAttributeDef @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@index([definitionId, isActive])
}

/// ///////////////////////////
/// ///////////////////////////
model Tax {
  id                    String             @id @default(cuid())
  jewelryId             String
  name                  String
  code                  String             @default("")
  taxType               TaxType            @default(OTHER)
  calculationType       TaxCalculationType @default(PERCENTAGE)
  rate                  Decimal?           @db.Decimal(10, 4)
  fixedAmount           Decimal?           @db.Decimal(18, 2)
  applyOn               TaxApplyOn         @default(TOTAL)
  includedInPrice       Boolean            @default(false)
  appliesOnSale         Boolean            @default(true) // se aplica al precio de venta
  appliesOnPurchase     Boolean            @default(true) // se aplica al costo de compra
  isRecoverable         Boolean            @default(false) // si true, no suma al costo (ej: IVA Crédito Fiscal)
  validFrom             DateTime?
  validTo               DateTime?
  isActive              Boolean            @default(true)
  allowDocumentOverride Boolean            @default(false) // si true, el comprobante puede excepcionarlo con auditoría
  isFavorite            Boolean            @default(false)
  isSystem              Boolean            @default(false)
  sortOrder             Int                @default(0)
  notes                 String             @default("")
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

/// ///////////////////////////
/// ///////////////////////////
model PaymentMethod {
  id              String                @id @default(cuid())
  jewelryId       String
  name            String
  code            String                @default("")
  type            PaymentMethodType     @default(OTHER)
  customTypeLabel String                @default("")
  adjustmentType  PaymentAdjustmentType @default(NONE)
  adjustmentValue Decimal?              @db.Decimal(10, 4)
  isFavorite      Boolean               @default(false)
  isActive        Boolean               @default(true)
  isSystem        Boolean               @default(false)
  sortOrder       Int                   @default(0)
  notes           String                @default("")
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  jewelry          Jewelry                  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  installmentPlans PaymentInstallmentPlan[]
  salePayments     SalePayment[]            @relation("SalePaymentMethod")
  // Etapa 1.1 — forma de pago seleccionada en el DRAFT (impacta total via
  // PaymentInstallmentPlan.interestRate). Distinto de `salePayments` (que
  // son cobros posteriores). El motor de totales lee `Sale.paymentMethodId`
  // + `Sale.paymentInstallments` en confirm para reproducir el ajuste.
  salesSelected    Sale[]                   @relation("SaleSelectedPaymentMethod")

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

model PaymentInstallmentPlan {
  id              String   @id @default(cuid())
  paymentMethodId String
  jewelryId       String
  installments    Int
  interestRate    Decimal  @db.Decimal(10, 4)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@index([paymentMethodId])
  @@index([jewelryId])
}

/// ///////////////////////////
/// ///////////////////////////
model ShippingCarrier {
  id                    String              @id @default(cuid())
  jewelryId             String
  name                  String
  code                  String              @default("")
  logoUrl               String              @default("")
  trackingUrl           String              @default("")
  freeShippingThreshold Decimal?            @db.Decimal(18, 2)
  type                  ShippingCarrierType @default(DELIVERY)
  warehouseId           String?
  provider              String?
  providerConfig        Json?
  city                  String              @default("")
  province              String              @default("")
  country               String              @default("")
  isFavorite            Boolean             @default(false)
  isActive              Boolean             @default(true)
  isSystem              Boolean             @default(false)
  sortOrder             Int                 @default(0)
  notes                 String              @default("")
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  jewelry   Jewelry        @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  warehouse Warehouse?     @relation("WarehousePickups", fields: [warehouseId], references: [id], onDelete: SetNull)
  rates     ShippingRate[]

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, type])
  @@index([warehouseId])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

model ShippingRate {
  id              String           @id @default(cuid())
  carrierId       String
  jewelryId       String
  name            String
  zones           Json             @default("[]")
  province        String           @default("")
  countries       Json             @default("[]")
  calculationMode ShippingCalcMode @default(FIXED)
  fixedPrice      Decimal?         @db.Decimal(18, 2)
  pricePerKg      Decimal?         @db.Decimal(18, 4)
  minWeight       Decimal?         @db.Decimal(10, 3)
  maxWeight       Decimal?         @db.Decimal(10, 3)
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  carrier ShippingCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  @@index([carrierId])
  @@index([jewelryId])
}

/// ///////////////////////////
/// ///////////////////////////
model Seller {
  id              String         @id @default(cuid())
  jewelryId       String
  firstName       String
  lastName        String
  displayName     String         @default("")
  documentType    String         @default("")
  documentNumber  String         @default("")
  email           String         @default("")
  phone           String         @default("")
  commissionType  CommissionType @default(NONE)
  commissionValue Decimal?       @db.Decimal(10, 4)
  commissionBase  CommissionBase @default(TOTAL)
  userId          String?        @unique
  isFavorite      Boolean        @default(false)
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  notes           String         @default("")
  avatarUrl       String         @default("")
  street          String         @default("")
  streetNumber    String         @default("")
  city            String         @default("")
  province        String         @default("")
  country         String         @default("")
  postalCode      String         @default("")
  contactName     String         @default("")
  contactPhone    String         @default("")
  contactEmail    String         @default("")
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  jewelry            Jewelry            @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  user               User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  warehouses         SellerWarehouse[]
  attachments        SellerAttachment[]
  sales              Sale[]             @relation("SaleSeller")
  defaultForEntities CommercialEntity[] @relation("EntityDefaultSeller")

  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, isFavorite])
  @@index([jewelryId, deletedAt])
  @@index([deletedAt])
}

enum CommissionType {
  NONE
  PERCENTAGE
  FIXED_AMOUNT
}

enum CommissionBase {
  TOTAL // sobre el total de la línea (cantidad × precio − descuento), antes de impuestos
  TOTAL_AFTER_DISCOUNTS // sobre el total de la línea ajustado por canal + cupón, antes de impuestos
  TOTAL_AFTER_PAYMENT // sobre el total ajustado por canal + cupón + forma de pago (actualizado al cobrar)
  METAL // sobre el componente metal del breakdownSnapshot × cantidad
  HECHURA // sobre el componente hechura del breakdownSnapshot × cantidad
  METAL_Y_HECHURA // sobre metal + hechura combinados del breakdownSnapshot × cantidad
  HECHURA_AFTER_DISCOUNTS // sobre el componente hechura ajustado por canal + cupón
}

model SellerWarehouse {
  sellerId    String
  warehouseId String
  jewelryId   String

  seller    Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([sellerId, warehouseId])
  @@index([sellerId])
  @@index([warehouseId])
  @@index([jewelryId])
}

model SellerAttachment {
  id        String    @id @default(cuid())
  sellerId  String
  jewelryId String
  filename  String
  url       String
  mimeType  String    @default("")
  size      Int       @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([jewelryId])
  @@index([deletedAt])
}

model PriceList {
  id                       String            @id @default(cuid())
  jewelryId                String
  name                     String
  code                     String            @default("")
  description              String            @default("")
  scope                    PriceListScope    @default(GENERAL)
  categoryId               String?
  channelId                String?
  clientId                 String?
  mode                     PriceListMode     @default(MARGIN_TOTAL)
  marginTotal              Decimal?          @db.Decimal(10, 4)
  marginMetal              Decimal?          @db.Decimal(10, 4)
  marginHechura            Decimal?          @db.Decimal(10, 4)
  costPerGram              Decimal?          @db.Decimal(18, 6)
  surcharge                Decimal?          @db.Decimal(10, 4)
  minimumPrice             Decimal?          @db.Decimal(18, 2)
  roundingTarget           RoundingTarget    @default(NONE)
  roundingMode             RoundingMode      @default(NONE)
  roundingDirection        RoundingDirection @default(NEAREST)
  roundingApplyOn          RoundingApplyOn   @default(TOTAL)
  roundingModeHechura      RoundingMode      @default(NONE)
  roundingDirectionHechura RoundingDirection @default(NEAREST)
  roundingValueMetal       Decimal?          @db.Decimal(18, 4)
  roundingValueHechura     Decimal?          @db.Decimal(18, 4)
  // ── Etapa C-comercial — Redondeo comercial PHYSICAL (POLICY §R-Rounding-14)
  //
  // Contrato canónico del modo DESGLOSADO: metal padre físico (gramos) +
  // hechura/saldo monetario. Cuando `commercialRoundingMetalDomain="PHYSICAL"`,
  // el motor de lista (`pricing-engine.pricelist.ts`) redondea los gramos
  // del metal padre por línea y calcula `monetaryEquivalent = deltaGrams ×
  // metalPricePerGram`. Default MONETARY = compat hacia atrás (todas las
  // listas existentes siguen redondeando el subtotal $ del metal — legacy).
  //
  // Reusa el enum `DocumentRoundingMetalDomain` y el shape JSON de
  // `documentPhysicalRoundingConfig` (`{ byMetalParentId: { [id]: { mode,
  // direction } }, fallback: { mode, direction } }`). El motor solo lo
  // consume cuando `mode = METAL_HECHURA`.
  //
  // Anti doble redondeo: cuando `Jewelry.documentRoundingMetalDomain =
  // PHYSICAL` y la capa 16 financiera está activa, el motor suprime el
  // comercial PHYSICAL via `suppressListPhysicalRounding` (paralelo a
  // `suppressListDeferredRounding`). El comprobante manda.
  commercialRoundingMetalDomain    DocumentRoundingMetalDomain @default(MONETARY)
  commercialPhysicalRoundingConfig Json?
  // ── Etapa D' — Redondeo Comercial PER_DOCUMENT (POLICY §R-Rounding-15) ──
  //
  // Controla DÓNDE se ejecuta el redondeo comercial (metal físico + hechura):
  //   · PER_LINE_LEGACY (default): comportamiento histórico — applyPriceList
  //     redondea por línea, antes de impuestos.
  //   · PER_DOCUMENT: el motor de lista NO redondea per-línea; el redondeo se
  //     aplica POST-tax a nivel documento por `computeSaleDocumentTotals`
  //     (capa nueva post-tax, pre-shipping/payment). Hechura se redondea sobre
  //     el saldo monetario residual (= total comercial − valuación física).
  //
  // El default PER_LINE_LEGACY garantiza ZERO impacto en tenants existentes
  // hasta que el operador active PER_DOCUMENT por lista desde Configuración.
  commercialRoundingScope          CommercialRoundingScope     @default(PER_LINE_LEGACY)
  validFrom                DateTime?
  validTo                  DateTime?
  isFavorite               Boolean           @default(false)
  isActive                 Boolean           @default(true)
  sortOrder                Int               @default(0)
  notes                    String            @default("")
  // Balance Mode (POLICY.md §11 — Fase 3B.4). Nullable: null = hereda
  // siguiente nivel en R11.4 (tenant default). NO se aplica en runtime aún.
  balanceMode              BalanceMode?
  deletedAt                DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  jewelry           Jewelry            @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  category          ArticleCategory?   @relation("CategoryPriceLists", fields: [categoryId], references: [id], onDelete: SetNull)
  categoriesDefault ArticleCategory[]  @relation("DefaultPriceList")
  entityDefaults    CommercialEntity[] @relation("EntityPriceList")

  @@unique([jewelryId, code])
  @@index([jewelryId, deletedAt])
  @@index([jewelryId, deletedAt, isActive])
  @@index([jewelryId, deletedAt, isFavorite])
  @@index([jewelryId, scope])
  @@index([categoryId])
  @@index([channelId])
  @@index([clientId])
  @@index([deletedAt])
}

