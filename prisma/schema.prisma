/// ///////////////////////////
/// ARTÍCULOS
/// ///////////////////////////
model Article {
  id          String  @id @default(cuid())
  jewelryId   String
  code        String // ART-NNNN — autogenerado si no se provee
  name        String
  description String  @default("")
  categoryId  String?

  // ── Tipo y comportamiento ───────────────────────────────────────────────
  articleType ArticleType   @default(PRODUCT)
  status      ArticleStatus @default(DRAFT)
  stockMode   StockMode     @default(NO_STOCK)

  // ── Identidad comercial ─────────────────────────────────────────────────
  sku                 String        @default("") // código interno del tenant (libre, no impuesto único a nivel DB para no frenar importaciones)
  barcode             String? // código de barras — único por tenant cuando presente
  barcodeType         BarcodeType   @default(CODE128)
  barcodeSource       BarcodeSource @default(CUSTOM) // de dónde viene el barcode: CODE / SKU / CUSTOM
  brand               String        @default("") // marca
  manufacturer        String        @default("") // fabricante
  supplierCode        String        @default("") // código en el sistema del proveedor
  preferredSupplierId String? // proveedor habitual (FK a CommercialEntity isSupplier)

  // ── Precios y costos ────────────────────────────────────────────────────
  salePrice          Decimal? @db.Decimal(14, 4) // precio de venta manual; cuando useManualSalePrice=true, manda sobre lista
  useManualSalePrice Boolean  @default(false) // si true, salePrice es el precio efectivo (override explícito)
  mermaPercent       Decimal? @db.Decimal(5, 2)

  // ── Parámetros del ajuste global de costo (aplicado sobre ArticleCostLine) ──
  manualAdjustmentKind  String   @default("") // "" | "BONUS" | "SURCHARGE"
  manualAdjustmentType  String   @default("") // "" | "PERCENTAGE" | "FIXED_AMOUNT"
  manualAdjustmentValue Decimal? @db.Decimal(14, 4) // valor absoluto del ajuste
  manualTaxIds          String[] @default([]) // IDs de impuestos (solo visual, no componible)

  // ── Modo comercial (combo) ──────────────────────────────────────────────
  // Migración 20260423200000_add_article_commercial_mode. Los campos viven
  // en la DB pero quedaron sin reflejar en este schema; restaurados acá para
  // que el cliente Prisma los exponga (drift fix).
  commercialMode       ArticleCommercialMode @default(NORMAL)
  comboAdjustmentKind  ComboAdjustmentKind   @default(NONE)
  comboAdjustmentValue Decimal?              @db.Decimal(14, 4)

  // ── Comportamiento de variantes ─────────────────────────────────────────
  sellWithoutVariants Boolean @default(true) // si true, el artículo padre puede venderse sin elegir variante

  // ── Flags comerciales ───────────────────────────────────────────────────
  isReturnable  Boolean  @default(true)
  showInStore   Boolean  @default(false) // visible en tienda / catálogo web
  unitOfMeasure String   @default("") // "unidad", "par", "set", etc.
  reorderPoint  Decimal? @db.Decimal(14, 4) // stock mínimo para alerta de reposición

  // ── Dimensiones físicas ─────────────────────────────────────────────────
  dimensionLength Decimal? @db.Decimal(10, 4)
  dimensionWidth  Decimal? @db.Decimal(10, 4)
  dimensionHeight Decimal? @db.Decimal(10, 4)
  dimensionUnit   String   @default("cm")
  weight          Decimal? @db.Decimal(10, 4) // peso del artículo
  weightUnit      String   @default("") // unidad de peso (g, kg, oz, etc.)

  // ── Cantidades de venta ─────────────────────────────────────────────────
  minSaleQuantity Decimal? @db.Decimal(14, 4)
  maxSaleQuantity Decimal? @db.Decimal(14, 4)
  defaultQuantity Decimal? @db.Decimal(14, 4)

  // ── Contabilidad ────────────────────────────────────────────────────────
  inventoryAccount String @default("") // cuenta contable de inventario (opcional)

  // ── Control y visibilidad ───────────────────────────────────────────────
  mainImageUrl String    @default("")
  isFavorite   Boolean   @default(false)
  isActive     Boolean   @default(true)
  notes        String    @default("")
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  jewelry           Jewelry                 @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  category          ArticleCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  preferredSupplier CommercialEntity?       @relation("ArticlePreferredSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  variants          ArticleVariant[]
  attributeValues   ArticleAttributeValue[]
  images            ArticleImage[]
  stock             ArticleStock[]
  movementLines     ArticleMovementLine[]
  saleLines         SaleLine[]
  purchaseLines     PurchaseLine[]          @relation("PurchaseLineArticle")
  costComposition   ArticleCostLine[]
  costLineRefs      ArticleCostLine[]       @relation("CostLineRefArticle")
  promotionArticles PromotionArticle[]      @relation("ArticlePromotions")
  quantityDiscounts QuantityDiscount[]      @relation("ArticleQuantityDiscounts")
  couponArticles    CouponArticle[]
  groupItems        ArticleGroupItem[]
  receiptLines      ReceiptLine[]

  @@unique([jewelryId, code])
  @@unique([jewelryId, barcode]) // barcode único por tenant (NULLs excluidos del check)
  @@index([jewelryId])
  @@index([categoryId])
  @@index([preferredSupplierId])
  @@index([jewelryId, status])
  @@index([jewelryId, isActive])
  @@index([jewelryId, articleType])
  @@index([jewelryId, sku])
  @@index([jewelryId, barcode])
  @@index([jewelryId, commercialMode])
  @@index([deletedAt])
}

