/// ///////////////////////////
/// ARTÍCULOS
/// ///////////////////////////
model Article {
  id               String           @id @default(cuid())
  jewelryId        String
  code             String           // ART-NNNN — autogenerado si no se provee
  name             String
  description      String           @default("")
  categoryId       String?

  // ── Tipo y comportamiento ───────────────────────────────────────────────
  articleType         ArticleType      @default(PRODUCT)
  status              ArticleStatus    @default(DRAFT)
  stockMode           StockMode        @default(NO_STOCK)

  // ── Identidad comercial ─────────────────────────────────────────────────
  sku                 String           @default("")  // código interno del tenant (libre, no impuesto único a nivel DB para no frenar importaciones)
  barcode             String?          // código de barras — único por tenant cuando presente
  barcodeType         BarcodeType      @default(CODE128)
  barcodeSource       BarcodeSource    @default(CUSTOM) // de dónde viene el barcode: CODE / SKU / CUSTOM
  brand               String           @default("")  // marca
  manufacturer        String           @default("")  // fabricante
  supplierCode        String           @default("")  // código en el sistema del proveedor
  preferredSupplierId String?          // proveedor habitual (FK a CommercialEntity isSupplier)

  // ── Precios y costos ────────────────────────────────────────────────────
  salePrice           Decimal?         @db.Decimal(14, 4)  // precio de venta manual; cuando useManualSalePrice=true, manda sobre lista
  useManualSalePrice  Boolean          @default(false)     // si true, salePrice es el precio efectivo (override explícito)
  mermaPercent        Decimal?         @db.Decimal(5, 2)

  // ── Parámetros del ajuste global de costo (aplicado sobre ArticleCostLine) ──
  manualAdjustmentKind  String           @default("")        // "" | "BONUS" | "SURCHARGE"
  manualAdjustmentType  String           @default("")        // "" | "PERCENTAGE" | "FIXED_AMOUNT"
  manualAdjustmentValue Decimal?         @db.Decimal(14, 4)  // valor absoluto del ajuste
  manualTaxIds          String[]         @default([])         // IDs de impuestos (solo visual, no componible)

  // ── Modo comercial (combo) ──────────────────────────────────────────────
  // Migración 20260423200000_add_article_commercial_mode. Los campos viven
  // en la DB pero quedaron sin reflejar en este schema; restaurados acá para
  // que el cliente Prisma los exponga (drift fix).
  commercialMode       ArticleCommercialMode @default(NORMAL)
  comboAdjustmentKind  ComboAdjustmentKind   @default(NONE)
  comboAdjustmentValue Decimal?              @db.Decimal(14, 4)

  // ── Comportamiento de variantes ─────────────────────────────────────────
  sellWithoutVariants Boolean          @default(true) // si true, el artículo padre puede venderse sin elegir variante

  // ── Flags comerciales ───────────────────────────────────────────────────
  isReturnable        Boolean          @default(true)
  showInStore         Boolean          @default(false)  // visible en tienda / catálogo web
  unitOfMeasure       String           @default("")     // "unidad", "par", "set", etc.
  reorderPoint        Decimal?         @db.Decimal(14, 4) // stock mínimo para alerta de reposición

  // ── Dimensiones físicas ─────────────────────────────────────────────────
  dimensionLength     Decimal?         @db.Decimal(10, 4)
  dimensionWidth      Decimal?         @db.Decimal(10, 4)
  dimensionHeight     Decimal?         @db.Decimal(10, 4)
  dimensionUnit       String           @default("cm")
  weight              Decimal?         @db.Decimal(10, 4) // peso del artículo
  weightUnit          String           @default("")       // unidad de peso (g, kg, oz, etc.)

  // ── Cantidades de venta ─────────────────────────────────────────────────
  minSaleQuantity     Decimal?         @db.Decimal(14, 4)
  maxSaleQuantity     Decimal?         @db.Decimal(14, 4)
  defaultQuantity     Decimal?         @db.Decimal(14, 4)

  // ── Contabilidad ────────────────────────────────────────────────────────
  inventoryAccount    String           @default("")       // cuenta contable de inventario (opcional)

  // ── Control y visibilidad ───────────────────────────────────────────────
  mainImageUrl        String           @default("")
  isFavorite          Boolean          @default(false)
  isActive            Boolean          @default(true)
  notes               String           @default("")
  deletedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  jewelry           Jewelry                   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  category          ArticleCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  preferredSupplier CommercialEntity?         @relation("ArticlePreferredSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  variants          ArticleVariant[]
  attributeValues   ArticleAttributeValue[]
  images            ArticleImage[]
  stock             ArticleStock[]
  movementLines     ArticleMovementLine[]
  saleLines         SaleLine[]
  purchaseLines     PurchaseLine[]     @relation("PurchaseLineArticle")
  costComposition   ArticleCostLine[]
  costLineRefs      ArticleCostLine[]  @relation("CostLineRefArticle")
  promotionArticles PromotionArticle[] @relation("ArticlePromotions")
  quantityDiscounts QuantityDiscount[] @relation("ArticleQuantityDiscounts")
  couponArticles    CouponArticle[]
  groupItems        ArticleGroupItem[]
  receiptLines      ReceiptLine[]

  @@unique([jewelryId, code])
  @@unique([jewelryId, barcode])         // barcode único por tenant (NULLs excluidos del check)
  @@index([jewelryId])
  @@index([categoryId])
  @@index([preferredSupplierId])
  @@index([jewelryId, status])
  @@index([jewelryId, isActive])
  @@index([jewelryId, articleType])
  @@index([jewelryId, sku])
  @@index([jewelryId, barcode])
  @@index([jewelryId, commercialMode])
  @@index([deletedAt])
}

// FASE combo comercial — tipos del modo comercial del artículo. Migración
// 20260423200000_add_article_commercial_mode (existente en DB).
enum ArticleCommercialMode {
  NORMAL
  COMBO_COMMERCIAL
}

enum ComboAdjustmentKind {
  NONE
  DISCOUNT_PERCENT
  DISCOUNT_FIXED
  SURCHARGE_PERCENT
}

// ---------------------------------------------------------------------------
// Grupo comercial de artículos — capa de presentación para web/catálogo
// ---------------------------------------------------------------------------
model ArticleGroup {
  id            String    @id @default(cuid())
  jewelryId     String
  name          String
  slug          String
  description   String    @default("")
  mainImageUrl  String    @default("")
  selectorLabel String    @default("")  // ej: "Ancho", "Talle"
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  jewelry          Jewelry            @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  items            ArticleGroupItem[]
  images           ArticleGroupImage[]
  promotionGroups  PromotionGroup[]
  quantityDiscounts QuantityDiscount[] @relation("GroupQuantityDiscounts")
  couponGroups     CouponGroup[]

  @@unique([jewelryId, slug])
  @@index([jewelryId])
  @@index([deletedAt])
}

model ArticleGroupImage {
  id        String   @id @default(cuid())
  groupId   String
  jewelryId String
  url       String
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  group ArticleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([jewelryId])
}

// ---------------------------------------------------------------------------
// Ítem vendible dentro de un grupo — soporta variante, artículo simple o servicio
// ---------------------------------------------------------------------------
enum GroupItemType {
  ARTICLE
  VARIANT
}

model ArticleGroupItem {
  id                 String        @id @default(cuid())
  groupId            String
  jewelryId          String
  itemType           GroupItemType
  articleId          String?
  variantId          String?
  groupOrder         Int           @default(0)
  groupSelectorValue String        @default("")
  createdAt          DateTime      @default(now())

  group   ArticleGroup    @relation(fields: [groupId],  references: [id], onDelete: Cascade)
  article Article?        @relation(fields: [articleId], references: [id], onDelete: Cascade)
  variant ArticleVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([jewelryId])
  @@index([articleId])
  @@index([variantId])
}

/// Tipo de componente en la composición de costo por líneas
enum CostLineType {
  METAL    // gramos × cotización × (1 + merma%)
  HECHURA  // mano de obra / fabricación
  PRODUCT  // insumo / producto externo
  SERVICE  // servicio externo
  MANUAL   // costo libre (descripción + cantidad + precio unitario)
}

/// Composición de costo del artículo por líneas.
/// Cada artículo tiene una o más líneas; la suma es el costo total.
model ArticleCostLine {
  id               String       @id @default(cuid())
  articleId        String
  jewelryId        String
  type             CostLineType @default(MANUAL)
  label            String       @default("")
  quantity         Decimal      @default(1)  @db.Decimal(14, 4)
  unitValue        Decimal      @default(0)  @db.Decimal(18, 6)
  currencyId       String?                                        // null = moneda base del tenant
  mermaPercent     Decimal?                  @db.Decimal(5, 2)   // solo para type=METAL
  metalVariantId   String?                                        // solo para type=METAL
  catalogItemId    String?                                        // para tipo PRODUCT/SERVICE: ID del artículo catálogo referenciado
  // FASE 2 — variante específica del componente (opcional). Si está presente,
  // su `articleId` debe coincidir con `catalogItemId` (validación a nivel app).
  // Cuando se descuenta stock por affectsStock=true, se usa esta variante.
  catalogVariantId String?
  lineAdjKind      String       @default("")                      // "" | "BONUS" | "SURCHARGE"
  lineAdjType      String       @default("")                      // "" | "PERCENTAGE" | "FIXED_AMOUNT"
  lineAdjValue     Decimal?                  @db.Decimal(14, 4)  // valor del ajuste por línea
  sortOrder        Int          @default(0)
  affectsStock     Boolean      @default(false)                    // solo para type=PRODUCT/SERVICE: descuenta stock del componente al confirmar venta
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  article        Article         @relation(fields: [articleId],     references: [id], onDelete: Cascade)
  currency       Currency?       @relation("CostLineCurrency",     fields: [currencyId],     references: [id])
  metalVariant   MetalVariant?   @relation("CostLineMetalVariant", fields: [metalVariantId], references: [id])
  catalogItem    Article?        @relation("CostLineRefArticle",   fields: [catalogItemId],  references: [id])
  catalogVariant ArticleVariant? @relation("CostLineRefVariant",   fields: [catalogVariantId], references: [id], onDelete: SetNull)

  @@index([articleId])
  @@index([jewelryId])
  @@index([catalogVariantId])
}


model ArticleVariant {
  id                   String      @id @default(cuid())
  articleId            String
  jewelryId            String
  code                 String      // código único dentro del artículo
  name                 String

  // ── Identidad comercial ─────────────────────────────────────────────────
  sku                  String        @default("")
  barcode              String?       // único por tenant cuando presente
  barcodeType          BarcodeType   @default(CODE128)
  barcodeSource        BarcodeSource @default(CUSTOM) // de dónde viene el barcode: CODE / SKU / CUSTOM

  // ── Peso override ───────────────────────────────────────────────────────
  // REGLA: Las variantes no tienen precio ni costo propios. Toda la lógica
  // de precio, costo, impuestos y flags comerciales reside en el artículo padre.
  // El único override permitido es el peso (afecta el cálculo de costo del padre).
  weightOverride       Decimal?    @db.Decimal(10, 4)

  // ── Inventario ──────────────────────────────────────────────────────────
  reorderPoint         Decimal?    @db.Decimal(14, 4) // stock mínimo para alerta de reposición (por variante)
  openingStock         Decimal?    @db.Decimal(14, 4) // existencia de apertura (stock inicial registrado al crear)

  // ── Cantidades de venta (override por variante) ─────────────────────────
  minSaleQuantity      Decimal?    @db.Decimal(14, 4)
  maxSaleQuantity      Decimal?    @db.Decimal(14, 4)
  defaultQuantity      Decimal?    @db.Decimal(14, 4)

  // ── Visual y control ────────────────────────────────────────────────────
  imageUrl             String      @default("")
  notes                String      @default("")
  isActive             Boolean     @default(true)
  isFavorite           Boolean?                    // null = heredar del artículo padre
  sortOrder            Int         @default(0)
  deletedAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  article           Article             @relation(fields: [articleId], references: [id], onDelete: Cascade)
  groupItems        ArticleGroupItem[]
  stock             ArticleStock[]
  movementLines     ArticleMovementLine[]
  saleLines         SaleLine[]
  purchaseLines     PurchaseLine[]     @relation("PurchaseLineVariant")
  promotionVariants PromotionVariant[]    @relation("VariantPromotions")
  quantityDiscounts QuantityDiscount[]   @relation("VariantQuantityDiscounts")
  couponVariants    CouponVariant[]
  attributeValues   ArticleVariantAttributeValue[]
  images            ArticleVariantImage[]
  costLineRefs      ArticleCostLine[]  @relation("CostLineRefVariant")
  receiptLines      ReceiptLine[]

  @@unique([articleId, code])
  @@unique([jewelryId, barcode])   // barcode único por tenant (NULLs excluidos)
  @@index([articleId])
  @@index([jewelryId])
  @@index([jewelryId, sku])
  @@index([jewelryId, barcode])
}

model ArticleAttributeValue {
  id           String   @id @default(cuid())
  articleId    String
  jewelryId    String
  assignmentId String
  value        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article    Article                  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assignment ArticleCategoryAttribute @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([articleId, assignmentId])
  @@index([articleId])
  @@index([assignmentId])
}

/// Valores de atributos con isVariantAxis=true asignados a cada variante.
/// Mismo patrón que ArticleAttributeValue pero para ArticleVariant.
model ArticleVariantAttributeValue {
  id           String   @id @default(cuid())
  jewelryId    String
  variantId    String
  assignmentId String   // FK → ArticleCategoryAttribute (debe tener isVariantAxis=true)
  value        String   @default("") // serialización unificada (igual que ArticleAttributeValue)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  variant    ArticleVariant           @relation(fields: [variantId], references: [id], onDelete: Cascade)
  assignment ArticleCategoryAttribute @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([variantId, assignmentId])
  @@index([variantId])
  @@index([assignmentId])
  @@index([jewelryId])
}

model ArticleImage {
  id        String   @id @default(cuid())
  articleId String
  jewelryId String
  url       String
  label     String   @default("")
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([jewelryId])
}

model ArticleVariantImage {
  id        String   @id @default(cuid())
  variantId String
  articleId String
  jewelryId String
  url       String
  label     String   @default("")
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  variant ArticleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([articleId])
  @@index([jewelryId])
}

model ArticleStock {
  id           String    @id @default(cuid())
  articleId    String
  variantId    String?
  warehouseId  String
  jewelryId    String
  quantity     Decimal   @default(0) @db.Decimal(14, 4)
  reservedQty  Decimal   @default(0) @db.Decimal(14, 4) // reservado para pedidos futuros — no se descuenta de quantity todavía
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  article   Article         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  variant   ArticleVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([jewelryId, warehouseId, articleId, variantId])
  @@index([articleId])
  @@index([jewelryId])
  @@index([warehouseId])
}

/// ///////////////////////////
/// ENUMS — ARTÍCULOS
/// ///////////////////////////
enum ArticleStatus {
  DRAFT
  ACTIVE
  DISCONTINUED
  ARCHIVED
}

enum StockMode {
  NO_STOCK
  BY_ARTICLE
  BY_MATERIAL
}


/// Tipo de artículo — define el comportamiento esperado (stock, composición, etc.)
/// PRODUCT  → joya o artículo físico fabricable. stockMode: NO_STOCK | BY_ARTICLE | BY_MATERIAL
/// SERVICE  → servicio (reparación, diseño, etc.). stockMode forzado a NO_STOCK. Sin variantes.
/// MATERIAL → insumo no metálico comprado (cierres, cadenas). stockMode: NO_STOCK | BY_ARTICLE
enum ArticleType {
  PRODUCT
  SERVICE
  MATERIAL
}

/// Simbología de código de barras soportada
enum BarcodeType {
  CODE128  // Alfanumérico general — usado internamente y para uso flexible
  EAN13    // Estándar retail — 13 dígitos con dígito verificador
  QR       // QR code — para uso futuro (etiquetas digitales, etc.)
}


/// De dónde proviene el barcode de un artículo o variante
/// CODE   → el barcode es igual al campo `code` del artículo/variante (se sincroniza automáticamente)
/// SKU    → el barcode es igual al campo `sku` (se sincroniza automáticamente)
/// CUSTOM → el usuario escribe el barcode manualmente
enum BarcodeSource {
  CODE
  SKU
  CUSTOM
}


/// Tipos de movimiento de stock de artículos terminados
enum ArticleMovementKind {
  IN        // Entrada de stock (compra, devolución de cliente, etc.)
  OUT       // Salida de stock (venta, pérdida, etc.)
  TRANSFER  // Transferencia entre almacenes
  ADJUST    // Ajuste de inventario (cantidad absoluta nueva)
  OPENING   // Apertura de inventario (carga inicial)
}

/// Estado funcional del movimiento.
/// DRAFT   → borrador, no impacta stock.
/// CONFIRMED → confirmado, impacta stock.
/// VOIDED  → anulado, efectos revertidos.
enum MovementStatus {
  DRAFT
  CONFIRMED
  VOIDED
}

/// Cabecera de movimiento de stock de artículos terminados
/// Análogo a InventoryMovement pero para artículos (unidades) en vez de metal (gramos)
model ArticleMovement {
  id              String              @id @default(cuid())
  jewelryId       String
  kind            ArticleMovementKind
  status          MovementStatus      @default(CONFIRMED) // DRAFT | CONFIRMED | VOIDED
  sourceType      String              @default("MANUAL") // MANUAL | SALE | IMPORT | PURCHASE
  code            String              @default("") // AE/AS/AT/AA/AO-NNNN
  note            String              @default("")
  effectiveAt     DateTime
  warehouseId     String?             // IN / OUT / ADJUST / OPENING
  fromWarehouseId String?             // TRANSFER — origen
  toWarehouseId   String?             // TRANSFER — destino
  createdById     String?
  voidedAt        DateTime?
  voidedNote      String              @default("")
  voidedById      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  jewelry       Jewelry               @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  warehouse     Warehouse?            @relation("ArticleMovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  fromWarehouse Warehouse?            @relation("ArticleMovementFrom", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse?            @relation("ArticleMovementTo", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  createdBy     User?                 @relation("ArticleMovementCreatedBy", fields: [createdById], references: [id])
  voidedBy      User?                 @relation("ArticleMovementVoidedBy", fields: [voidedById], references: [id])
  lines              ArticleMovementLine[]
  sale               Sale?                 @relation("SaleStockMovement")
  saleComponent      Sale?                 @relation("SaleComponentMovement")

  @@index([jewelryId, createdAt])
  @@index([jewelryId, effectiveAt])
  @@index([jewelryId, kind])
  @@index([jewelryId, status])
  @@index([jewelryId, sourceType])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([jewelryId, voidedAt])
}

/// Línea de movimiento de artículo — un movimiento puede afectar múltiples artículos
model ArticleMovementLine {
  id         String          @id @default(cuid())
  movementId String
  jewelryId  String
  articleId  String
  variantId  String?
  // quantity semántica según kind del movimiento padre:
  //   IN / OUT / OPENING / TRANSFER: magnitud positiva (dirección implícita por kind)
  //   ADJUST: delta firmado (positivo = aumentar, negativo = disminuir)
  quantity      Decimal         @db.Decimal(14, 4)
  weightPerUnit Decimal?        @db.Decimal(10, 4)  // peso por unidad (snapshot al crear)
  totalWeight   Decimal?        @db.Decimal(14, 4)  // weightPerUnit × quantity
  snapshot      Json?           // snapshot histórico de nombre/imagen/metales (write-once al crear)
  createdAt     DateTime        @default(now())

  movement ArticleMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  article  Article         @relation(fields: [articleId], references: [id], onDelete: Restrict)
  variant  ArticleVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([movementId])
  @@index([articleId])
  @@index([variantId])
  @@index([jewelryId])
}

enum EntityRelationType {
  CLIENT_OF
  SUPPLIES_TO
  SAME_GROUP
  RELATED_COMPANY
  REFERRED_BY
  OTHER
}

/// Merma % override por variante por entidad comercial
model EntityMermaOverride {
  id           String     @id @default(cuid())
  entityId     String
  jewelryId    String
  variantId    String
  role         EntityRole @default(CLIENT)
  mermaPercent Decimal    @db.Decimal(5, 2)
  notes        String     @default("")
  isActive     Boolean    @default(true)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  entity  CommercialEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  variant MetalVariant     @relation(fields: [variantId], references: [id])

  @@unique([entityId, variantId, role])
  @@index([entityId])
  @@index([jewelryId])
  @@index([variantId])
  @@index([deletedAt])
}

/// Relación entre dos entidades comerciales del mismo tenant
model EntityRelation {
  id           String             @id @default(cuid())
  jewelryId    String
  fromEntityId String
  toEntityId   String
  relationType EntityRelationType @default(OTHER)
  notes        String             @default("")
  isActive     Boolean            @default(true)
  deletedAt    DateTime?
  createdAt    DateTime           @default(now())

  fromEntity CommercialEntity @relation("RelationFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity   CommercialEntity @relation("RelationTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@unique([fromEntityId, toEntityId, relationType])
  @@index([jewelryId])
  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([deletedAt])
}

/// ///////////////////////////
/// VENTAS
/// ///////////////////////////
enum SaleStatus {
  DRAFT           // en construcción — sin stock descontado
  CONFIRMED       // confirmada — stock descontado, pendiente de cobro
  PAID            // cobrada completamente
  PARTIALLY_PAID  // cobrada parcialmente
  CANCELLED       // anulada — stock restituido si fue CONFIRMED
}

model Sale {
  id              String     @id @default(cuid())
  jewelryId       String
  code            String     // VTA-0001 — autogenerado al crear
  status          SaleStatus @default(DRAFT)

  // ── Partes ───────────────────────────────────────────────────────────────
  clientId        String?    // FK a CommercialEntity (isClient=true)
  clientSnapshot  Json?      // snapshot del cliente al momento de confirmación
  sellerId        String?    // FK a Seller
  sellerSnapshot  Json?      // snapshot del vendedor al momento de confirmación
  channelId       String?    // FK a SalesChannel (canal de venta — opcional)
  channelSnapshot Json?      // snapshot del canal al momento de confirmación
  couponId        String?    // FK a Coupon (cupón aplicado — opcional)
  couponSnapshot  Json?      // snapshot del cupón al momento de confirmación
  warehouseId     String?    // almacén de donde se descuenta el stock

  // ── Snapshots de contexto (escritura única al confirmar) ──────────────
  currencyId       String?   // ID de la moneda usada en la transacción
  currencySnapshot Json?     // snapshot de la moneda + cotización al confirmar
  issuerSnapshot   Json?     // snapshot de la joyería (emisor) al confirmar

  // ── Totales (calculados al confirmar, nunca recalculados después) ─────
  subtotal              Decimal    @default(0) @db.Decimal(14, 2)
  discountAmount        Decimal    @default(0) @db.Decimal(14, 2)
  taxAmount             Decimal    @default(0) @db.Decimal(14, 2)
  total                 Decimal    @default(0) @db.Decimal(14, 2)
  paidAmount            Decimal    @default(0) @db.Decimal(14, 2)
  sellerCommissionTotal Decimal?              @db.Decimal(14, 2)

  // ── Fechas y trazabilidad ────────────────────────────────────────────────
  saleDate        DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelNote      String     @default("")
  notes           String     @default("")

  createdById     String?
  confirmedById   String?
  cancelledById   String?
  stockMovementId     String?  @unique // movimiento OUT del artículo generado automáticamente al confirmar
  componentMovementId String?  @unique // movimiento OUT de componentes (PRODUCT/SERVICE affectsStock=true) al confirmar

  jewelry           Jewelry           @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  client            CommercialEntity? @relation("SaleClient", fields: [clientId], references: [id], onDelete: SetNull)
  seller            Seller?           @relation("SaleSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  channel           SalesChannel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)
  coupon            Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  warehouse         Warehouse?        @relation("SaleWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)
  stockMovement     ArticleMovement?  @relation("SaleStockMovement",     fields: [stockMovementId],     references: [id], onDelete: SetNull)
  componentMovement ArticleMovement?  @relation("SaleComponentMovement", fields: [componentMovementId], references: [id], onDelete: SetNull)
  createdBy     User?             @relation("SaleCreatedBy", fields: [createdById], references: [id])
  confirmedBy   User?             @relation("SaleConfirmedBy", fields: [confirmedById], references: [id])
  cancelledBy   User?             @relation("SaleCancelledBy", fields: [cancelledById], references: [id])
  lines            SaleLine[]
  payments         SalePayment[]
  couponRedemptions CouponRedemption[]
  receipts         Receipt[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, status])
  @@index([jewelryId, saleDate])
  @@index([clientId])
  @@index([sellerId])
  @@index([channelId])
  @@index([couponId])
  @@index([warehouseId])
  @@index([createdById])
}

model SaleLine {
  id          String  @id @default(cuid())
  saleId      String
  jewelryId   String
  articleId   String
  variantId   String?

  // ── Snapshot al momento de la venta ─────────────────────────────────────
  articleName String  @default("")
  variantName String  @default("")
  sku         String  @default("")
  barcode     String  @default("")

  // ── Precio y cantidad ────────────────────────────────────────────────────
  quantity    Decimal @db.Decimal(14, 4)
  unitPrice   Decimal @db.Decimal(14, 4)
  discountPct Decimal @default(0) @db.Decimal(10, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  // ── Snapshot de resolución de precio ────────────────────────────────────
  priceSource        String  @default("")   // PROMOTION | MANUAL_OVERRIDE | QUANTITY_DISCOUNT | PRICE_LIST | MANUAL_FALLBACK
  appliedPriceListId String?
  appliedPromotionId String?
  appliedDiscountId  String?

  // ── Snapshot de costo y margen (congelado al confirmar) ──────────────────
  unitCost      Decimal? @db.Decimal(14, 4) // costo unitario al momento de confirmar
  totalCost     Decimal? @db.Decimal(14, 2) // unitCost × quantity
  unitMargin    Decimal? @db.Decimal(14, 4) // unitPrice - unitCost (antes de descuento)
  totalMargin   Decimal? @db.Decimal(14, 2) // lineTotal - totalCost
  marginPercent Decimal? @db.Decimal(10, 4) // (totalMargin / lineTotal) × 100
  breakdownSnapshot       Json?                   // desglose Metal/Hechura al momento de confirmar
  sellerCommissionBase   Decimal? @db.Decimal(14, 2) // base de comisión por línea (importe)
  sellerCommissionAmount Decimal? @db.Decimal(14, 2) // comisión calculada por línea
  taxAmount     Decimal? @db.Decimal(14, 4) // impuesto unitario al momento de confirmar
  taxSnapshot   Json?                        // desglose de impuestos al momento de confirmar
  pricingSnapshot Json?                      // snapshot completo PricingLineSnapshot al confirmar

  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())

  sale    Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  article Article        @relation(fields: [articleId], references: [id], onDelete: Restrict)
  variant ArticleVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([articleId])
  @@index([variantId])
  @@index([jewelryId])
}

model SalePayment {
  id                String   @id @default(cuid())
  saleId            String
  jewelryId         String
  paymentMethodId   String?  // FK a PaymentMethod — null si fue eliminado
  paymentMethodName String   @default("")
  amount            Decimal  @db.Decimal(14, 2)
  installments      Int      @default(1)
  reference         String   @default("") // nro de autorización, cheque, etc.
  paidAt            DateTime @default(now())
  createdAt         DateTime @default(now())

  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation("SalePaymentMethod", fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([jewelryId])
  @@index([paymentMethodId])
}

/// ///////////////////////////
/// PROMOCIONES Y DESCUENTOS
/// ///////////////////////////

/// Alcance de una promoción: a qué artículos aplica.
enum PromotionScope {
  ALL       // todos los artículos
  ARTICLE   // artículos específicos (via PromotionArticle)
  VARIANT   // variantes específicas (via PromotionVariant)
  CATEGORY  // categorías de artículos (via PromotionCategory)
  BRAND     // marcas específicas (via PromotionBrand)
  GROUP     // grupo de artículos (via PromotionGroup)
  METALS    // variantes de metal (via PromotionMetalVariant) — aplica al artículo
            // si su composición de costo incluye al menos una de las variantes
            // seleccionadas. v1: combos NO heredan metales de sus componentes.
}

/// Tipo de ajuste de precio: descuento fijo o porcentual
enum PromotionType {
  FIXED       // descuento en monto fijo (moneda base)
  PERCENTAGE  // descuento en porcentaje sobre el precio base
}

/// Modo de evaluación de la cantidad para descuentos por volumen.
enum QuantityDiscountEvaluationMode {
  LINE           // cantidad de la línea individual (comportamiento clásico)
  CATEGORY_TOTAL // suma de cantidades de todas las líneas de la misma categoría en el comprobante
  BRAND_TOTAL    // suma de cantidades de todas las líneas de la misma marca en el comprobante
  GROUP_TOTAL    // suma de cantidades de todas las líneas del mismo grupo en el comprobante
}

/// Promoción especial por tiempo limitado o evento.
/// Prioridad máxima en la resolución de precio de venta.
model Promotion {
  id            String         @id @default(cuid())
  jewelryId     String
  name          String
  type          PromotionType
  value         Decimal           @db.Decimal(14, 4) // monto o % de descuento
  scope         PromotionScope    @default(ALL)       // alcance de la promoción
  applyOn       CommercialApplyOn @default(TOTAL)     // base de aplicación del descuento
  validFrom     DateTime?
  validTo       DateTime?
  untilStockEnd Boolean        @default(false)
  priority      Int            @default(0)        // menor número = mayor prioridad
  isStackable   Boolean        @default(true)     // si false, no se acumula con descuentos por cantidad
  isActive      Boolean        @default(true)
  notes         String         @default("")
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  jewelry       Jewelry                 @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  articles      PromotionArticle[]
  variants      PromotionVariant[]
  categories    PromotionCategory[]
  brands        PromotionBrand[]
  groups        PromotionGroup[]
  metalVariants PromotionMetalVariant[]

  @@index([jewelryId])
  @@index([scope])
  @@index([jewelryId, isActive])
  @@index([deletedAt])
}

/// Artículos específicos a los que aplica una promoción (scope = ARTICLE).
model PromotionArticle {
  id          String @id @default(cuid())
  promotionId String
  articleId   String
  jewelryId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  article   Article   @relation("ArticlePromotions", fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([promotionId, articleId])
  @@index([promotionId])
  @@index([articleId])
  @@index([jewelryId])
}

/// Variantes específicas a las que aplica una promoción (scope = VARIANT).
model PromotionVariant {
  id          String @id @default(cuid())
  promotionId String
  variantId   String
  jewelryId   String

  promotion Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  variant   ArticleVariant @relation("VariantPromotions", fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([promotionId, variantId])
  @@index([promotionId])
  @@index([variantId])
  @@index([jewelryId])
}

/// Categorías a las que aplica una promoción (scope = CATEGORY).
model PromotionCategory {
  id          String @id @default(cuid())
  promotionId String
  categoryId  String
  jewelryId   String

  promotion Promotion       @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category  ArticleCategory @relation("CategoryPromotions", fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promotionId, categoryId])
  @@index([promotionId])
  @@index([categoryId])
  @@index([jewelryId])
}

/// Marcas a las que aplica una promoción (scope = BRAND).
model PromotionBrand {
  id          String @id @default(cuid())
  promotionId String
  brand       String
  jewelryId   String

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, brand])
  @@index([promotionId])
  @@index([jewelryId])
}

/// Grupos de artículos a los que aplica una promoción (scope = GROUP).
model PromotionGroup {
  id          String @id @default(cuid())
  promotionId String
  groupId     String
  jewelryId   String

  promotion Promotion    @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  group     ArticleGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([promotionId, groupId])
  @@index([promotionId])
  @@index([groupId])
  @@index([jewelryId])
}

/// Variantes de metal a las que aplica una promoción (scope = METALS).
/// Aplica al artículo si su composición de costo (líneas tipo METAL)
/// incluye al menos una de las variantes seleccionadas.
model PromotionMetalVariant {
  id             String @id @default(cuid())
  promotionId    String
  metalVariantId String
  jewelryId      String

  promotion    Promotion    @relation(fields: [promotionId],    references: [id], onDelete: Cascade)
  metalVariant MetalVariant @relation("PromotionMetalVariant", fields: [metalVariantId], references: [id], onDelete: Cascade)

  @@unique([promotionId, metalVariantId])
  @@index([promotionId])
  @@index([metalVariantId])
  @@index([jewelryId])
}

/// Descuento por volumen/cantidad mínima de compra.
/// Aplica cuando la cantidad en la línea de venta supera el umbral.
model QuantityDiscount {
  id          String    @id @default(cuid())
  jewelryId   String
  articleId   String?       // null cuando el alcance no es por artículo
  variantId   String?       // solo si scope es variante específica
  categoryId  String?       // null cuando el alcance no es por categoría
  brand       String?       // null cuando el alcance no es por marca
  groupId     String?       // null cuando el alcance no es por grupo
  // Alcance por variantes de metal (scope METALS). Aplica si la composición
  // del artículo incluye al menos una de las variantes listadas. Vacío
  // significa que la regla no usa scope por metales. v1: combos NO heredan.
  metalVariantIds String[]                    @default([])
  isActive        Boolean                        @default(true)
  isStackable     Boolean                        @default(true)     // si false, no se acumula con promociones
  evaluationMode  QuantityDiscountEvaluationMode @default(LINE)     // cómo se evalúa la cantidad
  applyOn         CommercialApplyOn              @default(TOTAL)    // base de aplicación del descuento
  sortOrder       Int                            @default(0)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jewelry  Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  article  Article?         @relation("ArticleQuantityDiscounts", fields: [articleId], references: [id], onDelete: SetNull)
  variant  ArticleVariant?  @relation("VariantQuantityDiscounts", fields: [variantId], references: [id], onDelete: SetNull)
  category ArticleCategory? @relation("CategoryQuantityDiscounts", fields: [categoryId], references: [id], onDelete: SetNull)
  group    ArticleGroup?    @relation("GroupQuantityDiscounts", fields: [groupId], references: [id], onDelete: SetNull)
  tiers    QuantityDiscountTier[]

  @@index([jewelryId])
  @@index([articleId])
  @@index([variantId])
  @@index([categoryId])
  @@index([groupId])
  @@index([deletedAt])
}

/// Tramo individual de un descuento por cantidad.
model QuantityDiscountTier {
  id         String        @id @default(cuid())
  discountId String
  minQty     Decimal       @db.Decimal(14, 4)
  type       PromotionType
  value      Decimal       @db.Decimal(14, 4)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  discount QuantityDiscount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@index([discountId])
}

enum LabelElementType {
  TEXT
  BARCODE
  QR
  IMAGE
  LINE
}

enum PrinterType {
  THERMAL
  ZEBRA
  A4
  INKJET
}

/// Plantilla de etiqueta para impresión
model LabelTemplate {
  id          String   @id @default(cuid())
  jewelryId   String
  name        String
  widthMm     Decimal  @db.Decimal(8, 2)
  heightMm    Decimal  @db.Decimal(8, 2)
  dpi         Int      @default(203)
  orientation String   @default("portrait")
  bgColor     String   @default("#ffffff")
  defaultPrinterProfileId String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jewelry               Jewelry         @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  defaultPrinterProfile PrinterProfile? @relation(fields: [defaultPrinterProfileId], references: [id], onDelete: SetNull)
  elements              LabelElement[]

  @@index([jewelryId])
  @@index([deletedAt])
}

/// Elemento dentro de una plantilla de etiqueta
model LabelElement {
  id          String           @id @default(cuid())
  templateId  String
  type        LabelElementType
  label       String           @default("")
  fieldKey    String           @default("")
  x           Decimal          @db.Decimal(8, 2)
  y           Decimal          @db.Decimal(8, 2)
  width       Decimal          @db.Decimal(8, 2)
  height      Decimal          @db.Decimal(8, 2)
  fontSize    Int              @default(8)
  fontWeight  String           @default("normal")
  align       String           @default("left")
  visible     Boolean          @default(true)
  sortOrder   Int              @default(0)
  configJson  String           @default("{}")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  template LabelTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

/// Perfil de impresora para configurar el layout de impresión
model PrinterProfile {
  id              String      @id @default(cuid())
  jewelryId       String
  name            String
  type            PrinterType @default(THERMAL)
  dpi             Int         @default(203)
  pageWidthMm     Decimal     @db.Decimal(8, 2) @default(210)
  pageHeightMm    Decimal     @db.Decimal(8, 2) @default(297)
  marginTopMm     Decimal     @db.Decimal(8, 2) @default(5)
  marginLeftMm    Decimal     @db.Decimal(8, 2) @default(5)
  marginRightMm   Decimal     @db.Decimal(8, 2) @default(5)
  marginBottomMm  Decimal     @db.Decimal(8, 2) @default(5)
  gapHMm          Decimal     @db.Decimal(8, 2) @default(2)
  gapVMm          Decimal     @db.Decimal(8, 2) @default(2)
  columns         Int         @default(1)
  offsetXMm       Decimal     @db.Decimal(8, 2) @default(0)
  offsetYMm       Decimal     @db.Decimal(8, 2) @default(0)
  isDefault       Boolean     @default(false)
  isActive        Boolean     @default(true)
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  jewelry        Jewelry         @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  labelTemplates LabelTemplate[]

  @@index([jewelryId])
  @@index([deletedAt])
}

/// ///////////////////////////
/// COMPRAS A PROVEEDORES
/// ///////////////////////////

model Purchase {
  id               String         @id @default(cuid())
  jewelryId        String
  code             String         // CMP-0001 — autogenerado
  status           PurchaseStatus @default(DRAFT)

  supplierId       String
  supplierSnapshot Json?          // snapshot del proveedor al confirmar

  // ── Snapshots de contexto (escritura única al confirmar) ──────────────
  currencyId       String?        // ID de la moneda usada en la transacción
  currencySnapshot Json?          // snapshot de la moneda + cotización al confirmar
  issuerSnapshot   Json?          // snapshot de la joyería (emisor) al confirmar

  subtotal         Decimal        @default(0) @db.Decimal(14, 2)
  discountAmount   Decimal        @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal        @default(0) @db.Decimal(14, 2)
  total            Decimal        @default(0) @db.Decimal(14, 2)
  paidAmount       Decimal        @default(0) @db.Decimal(14, 2)

  purchaseDate     DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  cancelNote       String         @default("")
  notes            String         @default("")

  createdById      String?
  confirmedById    String?
  cancelledById    String?

  jewelry     Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  supplier    CommercialEntity @relation("PurchaseSupplier", fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy   User?            @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  confirmedBy User?            @relation("PurchaseConfirmedBy", fields: [confirmedById], references: [id])
  cancelledBy User?            @relation("PurchaseCancelledBy", fields: [cancelledById], references: [id])
  lines              PurchaseLine[]
  payments           PurchasePayment[]
  crossSettlements   CrossSettlement[]  @relation("CrossSettlementPurchase")
  receipts           Receipt[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, status])
  @@index([jewelryId, purchaseDate])
  @@index([supplierId])
}

model PurchaseLine {
  id                String          @id @default(cuid())
  purchaseId        String
  jewelryId         String
  articleId         String?
  variantId         String?

  articleName       String          @default("")
  variantName       String          @default("")
  sku               String          @default("")
  barcode           String          @default("")

  quantity          Decimal         @db.Decimal(14, 4)
  unitCost          Decimal         @db.Decimal(14, 4)
  lineTotal         Decimal         @db.Decimal(14, 2)

  breakdownSnapshot Json?
  pricingSnapshot   Json?   // snapshot CostSnapshot congelado al confirmar la compra

  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())

  purchase  Purchase        @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  article   Article?        @relation("PurchaseLineArticle", fields: [articleId], references: [id], onDelete: SetNull)
  variant   ArticleVariant? @relation("PurchaseLineVariant", fields: [variantId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([articleId])
  @@index([variantId])
  @@index([jewelryId])
}

model PurchasePayment {
  id          String    @id @default(cuid())
  purchaseId  String?   // null = pago general a proveedor, no asociado a compra específica
  jewelryId   String
  supplierId  String
  paymentDate DateTime  @default(now())
  note        String    @default("")
  createdAt   DateTime  @default(now())
  createdById String?
  voidedAt    DateTime?
  voidedBy    String?
  voidReason  String    @default("")

  jewelry     Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  purchase    Purchase?        @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  supplier    CommercialEntity @relation("PurchasePaymentSupplier", fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy   User?            @relation("PurchasePaymentCreatedBy", fields: [createdById], references: [id])
  components  PurchasePaymentComponent[]

  @@index([purchaseId])
  @@index([supplierId])
  @@index([jewelryId])
}

model PurchasePaymentComponent {
  id            String                       @id @default(cuid())
  paymentId     String
  jewelryId     String
  componentType PurchasePaymentComponentType
  amount        Decimal?                     @db.Decimal(14, 2)
  currency      String                       @default("ARS")
  metalId       String?
  variantId     String?
  gramsOriginal Decimal?                     @db.Decimal(14, 6)
  purity        Decimal?                     @db.Decimal(10, 6)
  gramsPure     Decimal?                     @db.Decimal(14, 6)
  createdAt     DateTime                     @default(now())

  payment PurchasePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([jewelryId])
  @@index([metalId])
}

// ---------------------------------------------------------------------------
// CrossSettlement — cabecera auditable de liquidaciones cruzadas entre
// componentes distintos de cuenta corriente (ej: USD cancela ARS, USD cancela Au)
// ---------------------------------------------------------------------------
model CrossSettlement {
  id               String                     @id @default(cuid())
  jewelryId        String
  supplierId       String
  targetPurchaseId String?
  status           CrossSettlementStatus      @default(CONFIRMED)

  // Componente entregado (lo que entrega el proveedor o pagamos nosotros)
  fromComponentType  CrossSettlementComponentType
  fromCurrency       String?
  fromMetalId        String?
  fromVariantId      String?
  fromGramsOriginal  Decimal?  @db.Decimal(14, 6)
  fromPurity         Decimal?  @db.Decimal(10, 6)
  fromGramsPure      Decimal?  @db.Decimal(14, 6)
  fromAmount         Decimal?  @db.Decimal(14, 2)

  // Componente cancelado (la deuda que se liquida)
  toComponentType  CrossSettlementComponentType
  toCurrency       String?
  toMetalId        String?
  toVariantId      String?
  toGramsOriginal  Decimal?  @db.Decimal(14, 6)
  toPurity         Decimal?  @db.Decimal(10, 6)
  toGramsPure      Decimal?  @db.Decimal(14, 6)
  toAmount         Decimal?  @db.Decimal(14, 2)

  // Conversión usada
  fxRate            Decimal?  @db.Decimal(18, 8)
  metalQuotePerGram Decimal?  @db.Decimal(18, 8)
  quoteCurrency     String?

  notes       String   @default("")
  createdAt   DateTime @default(now())
  confirmedAt DateTime?
  voidedAt    DateTime?
  voidReason  String   @default("")
  createdById String?
  voidedById  String?

  supplier       CommercialEntity @relation("CrossSettlementSupplier", fields: [supplierId], references: [id], onDelete: Restrict)
  targetPurchase Purchase?        @relation("CrossSettlementPurchase", fields: [targetPurchaseId], references: [id], onDelete: SetNull)
  createdBy      User?            @relation("CrossSettlementCreatedBy", fields: [createdById], references: [id])
  voidedBy       User?            @relation("CrossSettlementVoidedBy", fields: [voidedById], references: [id])

  @@index([jewelryId])
  @@index([supplierId])
  @@index([targetPurchaseId])
  @@index([createdAt])
  @@index([voidedAt])
}

// ── Plantillas de documentos (presupuesto, factura, remito, etc.) ──────────────
enum DocumentKind {
  PRESUPUESTO
  FACTURA
  REMITO
  ORDEN_COMPRA
  MOVIMIENTO_STOCK
}

model DocumentTemplate {
  id        String       @id @default(cuid())
  jewelryId String
  jewelry   Jewelry      @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  kind      DocumentKind
  name      String       @default("")
  isDefault Boolean      @default(true)
  isActive  Boolean      @default(true)

  // ── Layout ────────────────────────────────────────────────────────────────
  layoutType String @default("A4")

  // ── Header ────────────────────────────────────────────────────────────────
  headerLogoEnabled        Boolean @default(true)
  headerLogoSize           String  @default("18")
  headerLogoPosition       String  @default("left")
  headerLogoBorderRadius   Int     @default(20)
  headerShowName           Boolean @default(true)
  headerShowLegalName      Boolean @default(false)
  headerShowCuit           Boolean @default(true)
  headerShowAddress        Boolean @default(true)
  headerShowPhone          Boolean @default(true)
  headerShowEmail          Boolean @default(false)
  headerShowWebsite        Boolean @default(false)
  headerShowProductImage   Boolean @default(false)
  headerCustomText         String  @default("")

  // ── Página ────────────────────────────────────────────────────────────────
  pageSizePreset String  @default("A4")
  orientation    String  @default("portrait")
  isCustomSize   Boolean @default(false)
  pageWidthMm    Decimal @default(210) @db.Decimal(8, 2)
  pageHeightMm   Decimal @default(297) @db.Decimal(8, 2)
  marginTop      Decimal @default(15)  @db.Decimal(6, 2)
  marginRight    Decimal @default(15)  @db.Decimal(6, 2)
  marginBottom   Decimal @default(20)  @db.Decimal(6, 2)
  marginLeft     Decimal @default(15)  @db.Decimal(6, 2)

  // ── Tipografía y estilo ───────────────────────────────────────────────────
  fontFamily   String @default("inter")
  fontSizeBase Int    @default(10)
  accentColor  String @default("#1a1a1a")
  tableStyle   String @default("bordered")

  // ── Moneda y precios ──────────────────────────────────────────────────────
  currencyShowSymbol Boolean @default(true)
  currencyShowRate   Boolean @default(false)
  currencyDecimals   Int     @default(2)
  pricesIncludeTax   Boolean @default(false)

  // ── Pie de página ─────────────────────────────────────────────────────────
  footerText            String  @default("")
  footerLegalText       String  @default("")
  footerBankData        String  @default("")
  footerTerms           String  @default("")
  footerShowPageNumbers Boolean @default(true)
  footerPageFormat      String  @default("page_of_total")
  footerPagePosition    String  @default("bottom_right")

  // ── Secciones y columnas (JSON como texto) ────────────────────────────────
  sections       String @default("{}")
  columns        String @default("[]")
  columnsVersion Int    @default(1)

  // ── Timestamps ────────────────────────────────────────────────────────────
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([jewelryId, kind, layoutType])
  @@index([jewelryId])
}

/// ─── Historial de importaciones masivas ────────────────────────────────────
/// Registra cada importación ejecutada: quién, cuándo, qué tipo, resultado.
/// Sirve para auditoría y para poder rastrear cambios masivos de datos.
model ImportBatch {
  id          String   @id @default(cuid())
  jewelryId   String
  createdById String?
  importedAt  DateTime @default(now())

  /// Tipo de dato importado
  entityType  String   // "ARTICLE" | "COMMERCIAL_ENTITY"

  /// Nombre original del archivo subido (solo informativo)
  fileName    String   @default("")

  /// Modo de conflicto usado: "skip" | "update" | "upsert"
  onConflict  String   @default("skip")

  /// Totales de resultado
  totalRows   Int      @default(0)
  created     Int      @default(0)
  updated     Int      @default(0)
  skipped     Int      @default(0)
  errors      Int      @default(0)

  /// Estado general del batch
  /// SUCCESS = sin errores | PARTIAL = éxitos + errores | FAILED = solo errores o sin procesados
  status      String   @default("SUCCESS")

  jewelry   Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  createdBy User?            @relation("ImportBatchCreatedBy", fields: [createdById], references: [id])
  rows      ImportBatchRow[]

  @@index([jewelryId, importedAt])
  @@index([jewelryId, entityType])
  @@index([jewelryId, status])
}

/// ─── Detalle por fila de una importación ────────────────────────────────────
/// Cada fila del archivo importado se registra aquí con su resultado.
/// rawData solo se guarda para filas con actionResult = FAILED (para diagnóstico).
model ImportBatchRow {
  id           String   @id @default(cuid())
  batchId      String
  jewelryId    String

  /// Posición en los resultados del batch (1-based, secuencial)
  rowIndex     Int

  /// Nombre legible de la fila (displayName del servicio)
  displayName  String   @default("")

  /// Resultado de la acción
  /// CREATED | UPDATED | SKIPPED | FAILED | CONFLICT
  actionResult String

  /// Identificador principal de la fila (código, email, documento — el más específico disponible)
  identifier   String   @default("")

  /// Mensaje corto legible del resultado (primer error o descripción)
  message      String   @default("")

  /// Lista de errores de validación (null si no hubo errores)
  errors       Json?

  /// Datos originales de la fila (solo para FAILED v1 — para diagnóstico y descarga)
  rawData      Json?

  /// Payload estructurado para reintento (solo FAILED v2 artículos)
  /// { type: "article" | "variant", payload: Record<string, string> }
  retryPayload Json?

  createdAt    DateTime @default(now())

  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([batchId, actionResult])
  @@index([jewelryId])
}

// ─── Canal de Venta ──────────────────────────────────────────────────────────
// Ajuste comercial adicional que se aplica DESPUÉS de la lista de precios
// y ANTES de la forma de pago. Independiente de PriceList.
// Ejemplo: "Mercado Libre +30%", "Mayorista -10%"
// ─────────────────────────────────────────────────────────────────────────────

enum SalesChannelAdjustmentType {
  PERCENTAGE  // porcentaje sobre el precio unitario (puede ser negativo)
  FIXED       // monto fijo absoluto (puede ser negativo)
}

model SalesChannel {
  id              String                     @id @default(cuid())
  jewelryId       String
  name            String
  code            String                     @default("")
  adjustmentType  SalesChannelAdjustmentType
  adjustmentValue Decimal                    @db.Decimal(14, 4)
  isActive        Boolean                    @default(true)
  isFavorite      Boolean                    @default(false)
  sortOrder       Int                        @default(0)
  notes           String                     @default("")
  deletedAt       DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  sales   Sale[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, deletedAt])
  @@index([jewelryId, isActive])
}

/// ///////////////////////////
/// CUPONES
/// ///////////////////////////

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponScope {
  ALL
  CLIENT
  CATEGORY
  ARTICLE
  GROUP
  BRAND
  METALS  // variantes de metal (via CouponMetalVariant) — aplica si la línea
          // de venta tiene un artículo cuya composición incluye al menos una
          // de las variantes seleccionadas. v1: combos NO heredan metales.
}

/// Cupón de descuento ingresado manualmente por código en el momento de la venta.
/// Es independiente de Promotion (que es automática) y de QuantityDiscount.
/// Orden de aplicación: lista → canal → cupón → pago → impuestos → redondeo.
model Coupon {
  id              String            @id @default(cuid())
  jewelryId       String
  name            String
  code            String            // código ingresado por el usuario — único por jewelryId, normalizado UPPER en service
  description     String            @default("")
  discountType    CouponDiscountType
  discountValue   Decimal           @db.Decimal(14, 4)
  validFrom       DateTime?
  validTo         DateTime?
  maxUsesTotal    Int?              // null = sin límite total de usos
  maxUsesPerClient Int?             // null = sin límite por cliente
  applyScope      CouponScope       @default(ALL)
  isActive        Boolean           @default(true)
  notes           String            @default("")
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  jewelry       Jewelry              @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  redemptions   CouponRedemption[]
  articles      CouponArticle[]
  variants      CouponVariant[]
  categories    CouponCategory[]
  groups        CouponGroup[]
  clients       CouponClient[]
  brands        CouponBrand[]
  metalVariants CouponMetalVariant[]
  sales         Sale[]

  @@unique([jewelryId, code])
  @@index([jewelryId])
  @@index([jewelryId, isActive])
  @@index([jewelryId, deletedAt])
}

/// Registro de cada uso de un cupón (creado al confirmar la venta).
model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  jewelryId  String
  saleId     String?
  clientId   String?
  amount     Decimal  @db.Decimal(14, 4) // monto efectivamente descontado
  redeemedAt DateTime @default(now())

  coupon Coupon            @relation(fields: [couponId], references: [id], onDelete: Cascade)
  sale   Sale?             @relation(fields: [saleId],   references: [id], onDelete: SetNull)
  client CommercialEntity? @relation("CouponRedemptionClient", fields: [clientId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([saleId])
  @@index([clientId])
  @@index([jewelryId])
}

/// Artículos específicos a los que aplica un cupón (applyScope = ARTICLE).
model CouponArticle {
  id        String @id @default(cuid())
  couponId  String
  articleId String
  jewelryId String

  coupon  Coupon  @relation(fields: [couponId],  references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([couponId, articleId])
  @@index([couponId])
  @@index([articleId])
  @@index([jewelryId])
}

/// Variantes específicas a las que aplica un cupón (applyScope = ARTICLE).
model CouponVariant {
  id        String @id @default(cuid())
  couponId  String
  variantId String
  jewelryId String

  coupon  Coupon         @relation(fields: [couponId],  references: [id], onDelete: Cascade)
  variant ArticleVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([couponId, variantId])
  @@index([couponId])
  @@index([variantId])
  @@index([jewelryId])
}

/// Categorías a las que aplica un cupón (applyScope = CATEGORY).
model CouponCategory {
  id         String @id @default(cuid())
  couponId   String
  categoryId String
  jewelryId  String

  coupon   Coupon          @relation(fields: [couponId],   references: [id], onDelete: Cascade)
  category ArticleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([couponId, categoryId])
  @@index([couponId])
  @@index([categoryId])
  @@index([jewelryId])
}

/// Grupos de artículos a los que aplica un cupón (applyScope = GROUP).
model CouponGroup {
  id        String @id @default(cuid())
  couponId  String
  groupId   String
  jewelryId String

  coupon Coupon       @relation(fields: [couponId], references: [id], onDelete: Cascade)
  group  ArticleGroup @relation(fields: [groupId],  references: [id], onDelete: Cascade)

  @@unique([couponId, groupId])
  @@index([couponId])
  @@index([groupId])
  @@index([jewelryId])
}

/// Clientes específicos para los que es válido el cupón (applyScope = CLIENT).
model CouponClient {
  id        String @id @default(cuid())
  couponId  String
  clientId  String
  jewelryId String

  coupon Coupon           @relation(fields: [couponId], references: [id], onDelete: Cascade)
  client CommercialEntity @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([couponId, clientId])
  @@index([couponId])
  @@index([clientId])
  @@index([jewelryId])
}

/// Marcas de artículos a las que aplica un cupón (applyScope = BRAND).
model CouponBrand {
  id        String @id @default(cuid())
  couponId  String
  brandName String
  jewelryId String

  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  jewelry Jewelry @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@unique([couponId, brandName])
  @@index([couponId])
  @@index([jewelryId])
}

/// Variantes de metal a las que aplica un cupón (applyScope = METALS).
/// Aplica si el artículo de la línea de venta tiene en su composición de
/// costo al menos una de las variantes de metal seleccionadas.
model CouponMetalVariant {
  id             String @id @default(cuid())
  couponId       String
  metalVariantId String
  jewelryId      String

  coupon       Coupon       @relation(fields: [couponId],       references: [id], onDelete: Cascade)
  metalVariant MetalVariant @relation("CouponMetalVariant", fields: [metalVariantId], references: [id], onDelete: Cascade)

  @@unique([couponId, metalVariantId])
  @@index([couponId])
  @@index([metalVariantId])
  @@index([jewelryId])
}

/// ===========================================================================
/// FASE 5 — Comprobantes (Receipt) + Cuenta corriente
/// Migración: 20260424000000_add_receipts_current_account
/// ===========================================================================

enum ReceiptType {
  QUOTE
  INVOICE
  DELIVERY_NOTE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum ReceiptDirection {
  OUTBOUND
  INBOUND
}

enum ReceiptStatus {
  DRAFT
  ISSUED
  VOIDED
}

enum AccountMovementKind {
  DEBIT
  CREDIT
}

enum AccountMovementSource {
  RECEIPT
  PAYMENT_ALLOCATION
}

model ReceiptSeries {
  id          String           @id @default(cuid())
  jewelryId   String
  name        String
  type        ReceiptType
  direction   ReceiptDirection
  prefix      String           @default("")
  pointOfSale String           @default("0001")
  nextNumber  Int              @default(1)
  isActive    Boolean          @default(true)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  jewelry  Jewelry   @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  receipts Receipt[]

  @@unique([jewelryId, type, direction, prefix, pointOfSale])
  @@index([jewelryId])
  @@index([jewelryId, type, direction])
}

model Receipt {
  id                 String           @id @default(cuid())
  jewelryId          String
  seriesId           String
  code               String
  type               ReceiptType
  direction          ReceiptDirection
  status             ReceiptStatus    @default(DRAFT)
  saleId             String?
  purchaseId         String?
  correctedReceiptId String?
  counterpartyId     String?
  pricingSnapshot    Json
  currencySnapshot   Json
  currencyCode       String           @default("")
  currencyRate       Decimal          @default(1) @db.Decimal(18, 8)
  subtotal           Decimal          @default(0) @db.Decimal(14, 2)
  discountAmount     Decimal          @default(0) @db.Decimal(14, 2)
  taxAmount          Decimal          @default(0) @db.Decimal(14, 2)
  total              Decimal          @default(0) @db.Decimal(14, 2)
  totalBase          Decimal          @default(0) @db.Decimal(14, 2)
  issueDate          DateTime         @default(now())
  dueDate            DateTime?
  issuedAt           DateTime?
  voidedAt           DateTime?
  voidReason         String           @default("")
  notes              String           @default("")
  issuedById         String?
  voidedById         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  jewelry           Jewelry                  @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  series            ReceiptSeries            @relation(fields: [seriesId], references: [id], onDelete: Restrict)
  sale              Sale?                    @relation(fields: [saleId], references: [id], onDelete: Restrict)
  purchase          Purchase?                @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  correctedReceipt  Receipt?                 @relation("ReceiptCorrection", fields: [correctedReceiptId], references: [id], onDelete: Restrict)
  correctingReceipts Receipt[]               @relation("ReceiptCorrection")
  counterparty      CommercialEntity?        @relation("ReceiptCounterparty", fields: [counterpartyId], references: [id], onDelete: SetNull)
  issuedBy          User?                    @relation("ReceiptIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  voidedBy          User?                    @relation("ReceiptVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  lines             ReceiptLine[]
  accountMovements  CurrentAccountMovement[]

  @@unique([jewelryId, seriesId, code])
  @@index([jewelryId, type])
  @@index([jewelryId, status])
  @@index([jewelryId, issueDate])
  @@index([counterpartyId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([correctedReceiptId])
}

model ReceiptLine {
  id              String   @id @default(cuid())
  receiptId       String
  jewelryId       String
  pricingSnapshot Json
  articleId       String?
  variantId       String?
  itemKind        String
  name            String   @default("")
  code            String   @default("")
  sku             String   @default("")
  barcode         String   @default("")
  quantity        Decimal  @db.Decimal(14, 4)
  unitPrice       Decimal  @db.Decimal(14, 4)
  subtotal        Decimal  @db.Decimal(14, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal       Decimal  @db.Decimal(14, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(14, 2)
  totalWithTax    Decimal  @db.Decimal(14, 2)
  totalCost       Decimal? @db.Decimal(14, 2)
  totalMargin     Decimal? @db.Decimal(14, 2)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  receipt Receipt          @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  article Article?         @relation(fields: [articleId], references: [id], onDelete: SetNull)
  variant ArticleVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  jewelry Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([articleId])
  @@index([variantId])
  @@index([jewelryId])
}

model CurrentAccountMovement {
  id                  String                @id @default(cuid())
  jewelryId           String
  entityId            String
  kind                AccountMovementKind
  source              AccountMovementSource
  receiptId           String?
  paymentAllocationId String?
  amountBase          Decimal               @db.Decimal(14, 2)
  amountOriginal      Decimal               @db.Decimal(14, 2)
  currencySnapshot    Json
  currencyCode        String                @default("")
  currencyRate        Decimal               @db.Decimal(18, 8)
  movementDate        DateTime
  createdAt           DateTime              @default(now())
  notes               String                @default("")

  jewelry Jewelry          @relation(fields: [jewelryId], references: [id], onDelete: Cascade)
  entity  CommercialEntity @relation(fields: [entityId], references: [id], onDelete: Restrict)
  receipt Receipt?         @relation(fields: [receiptId], references: [id], onDelete: Restrict)

  @@index([jewelryId, entityId, movementDate])
  @@index([receiptId])
  @@index([paymentAllocationId])
}
